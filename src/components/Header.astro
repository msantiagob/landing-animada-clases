---
import Button from "./Button.astro";
import logoImg from "../assets/img/logo.webp";
import type { Link, NavLink } from "../types";

interface Props {
  logoUrl: string;
  logoAlt: string;
  links: NavLink[];
  link1?: Link;
  link2?: Link;
  link2ModalPlan?: string;
  langSwitcher?: { url: string; label: string };
}

const { logoUrl, logoAlt, link1, link2, link2ModalPlan, links, langSwitcher } = Astro.props;
---

<header>
  <sy-head>
    <div class="inner u-container">
      <div class="wrapper">
        <a class="logo" href={logoUrl}>
          <img src={logoImg.src} alt={logoAlt} />
        </a>

        <div class="menu">
          <ul>
            {
              links.map((l) =>
                l.groups ? (
                  <li class="has-dropdown">
                    <button class="nav-parent" aria-expanded="false" aria-haspopup="true">
                      {l.title}
                      <svg class="chevron" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
                        <path fill-rule="evenodd" d="M4.22 6.22a.75.75 0 0 1 1.06 0L8 8.94l2.72-2.72a.75.75 0 1 1 1.06 1.06l-3.25 3.25a.75.75 0 0 1-1.06 0L4.22 7.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd" />
                      </svg>
                    </button>
                    <div class="dropdown" role="menu" aria-hidden="true">
                      <div class="dropdown-grid">
                        {l.groups.map((group) => (
                          <div class="dropdown-col">
                            <p class="group-label">{group.label}</p>
                            <ul>
                              {group.items.map((item) => (
                                <li role="none">
                                  <a href={item.url} role="menuitem">
                                    {item.icon && (
                                      <span class="child-icon-wrap" aria-hidden="true">
                                        <span class="child-icon">{item.icon}</span>
                                      </span>
                                    )}
                                    <span class="child-text">
                                      <span class="child-title">{item.title}</span>
                                      {item.desc && (
                                        <span class="child-desc">{item.desc}</span>
                                      )}
                                    </span>
                                  </a>
                                </li>
                              ))}
                            </ul>
                          </div>
                        ))}
                      </div>
                    </div>
                  </li>
                ) : (
                  <li>
                    <a href={l.url}>{l.title}</a>
                  </li>
                )
              )
            }
          </ul>
        </div>

        <div class="buttons">
          {
            link1 ? (
              <a class="login" href={link1.url}>
                {link1.title}
              </a>
            ) : null
          }
          {
            langSwitcher ? (
              <a class="lang-switch" href={langSwitcher.url} aria-label={`Switch language to ${langSwitcher.label}`}>
                {langSwitcher.label}
              </a>
            ) : null
          }
          {
            link2 ? (
              <Button
                {...link2}
                revealable={false}
                modalPlan={link2ModalPlan}
              />
            ) : null
          }

          <button type="button" class="toggle" aria-label="">
            <span class="u-sr-only">Toggle Mobile Menu</span>
            <span aria-hidden>
              <span></span>
              <span></span>
              <span></span>
            </span>
          </button>
        </div>
      </div>
    </div>
  </sy-head>
</header>

<style>
  /* ── Shell ── */
  sy-head {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 10;
    color: var(--color-text);
    padding: 0.875rem 0;
    transition:
      padding 0.3s var(--ease-out-cubic),
      transform 0.3s var(--ease-out-cubic);
    will-change: transform;

    :global(body.is-nav-hidden) & {
      transform: translateY(-100%);
    }

    :global(body.is-nav-small) & {
      padding: 0.5rem 0;
    }
  }

  .inner {
    padding: 0;
  }

  /* ── Pill wrapper ── */
  .wrapper {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(10, 10, 22, 0.45);
    border: 1px solid rgba(255, 255, 255, 0.07);
    border-radius: 1rem;
    padding: 0.45rem 0.45rem 0.45rem 1.375rem;
    backdrop-filter: blur(28px);
    -webkit-backdrop-filter: blur(28px);
    transition:
      background 0.35s ease,
      border-color 0.35s ease,
      box-shadow 0.35s ease;

    :global(body.is-nav-small) & {
      background: rgba(7, 7, 15, 0.94);
      border-color: rgba(50, 170, 255, 0.1);
      box-shadow:
        0 8px 48px rgba(0, 0, 0, 0.55),
        0 1px 0 rgba(255, 255, 255, 0.04) inset;
    }

    @media (--mq-tablet) {
      border-radius: 0.875rem;
      padding: 0.5rem 0.5rem 0.5rem 1rem;

      :global(body.is-nav-opened) & {
        background: rgba(7, 7, 15, 0.98);
        border-color: rgba(50, 170, 255, 0.1);
      }
    }
  }

  /* ── Logo ── */
  .logo {
    position: relative;
    z-index: 3;
    flex-shrink: 0;

    img {
      height: 1.875rem;
      width: auto;
      display: block;
    }
  }

  /* ── Nav menu ── */
  .menu {
    display: flex;
    position: absolute;
    left: 0;
    right: 0;
    margin: 0 auto;
    width: max-content; /* prevents wrapping */

    @media (--mq-tablet) {
      align-items: flex-start;
      justify-content: center;
      width: 100vw;
      min-height: 100dvh;
      height: auto;
      position: fixed;
      z-index: 2;
      background: rgba(7, 7, 15, 0.98);
      top: 0;
      left: 0;
      clip-path: inset(0 0 0%);
      transition: clip-path 0.5s var(--ease-out-expo);
      will-change: clip-path;
      overflow-y: auto;
      padding: 5rem 0 4rem;

      :global(body:not(.is-nav-opened)) & {
        clip-path: inset(0 0 100%);
        pointer-events: none;
      }

      :global(body.is-nav-small:not(.is-nav-opened)) & {
        clip-path: inset(0 0 calc(100% - 4rem) round 0 0 0.875rem 0.875rem);
      }
    }

    @media (--mq-phone) {
      :global(body.is-nav-small:not(.is-nav-opened)) & {
        clip-path: inset(0 0 calc(100% - 3.5rem) round 0 0 0.875rem 0.875rem);
      }
    }

    :global(ul) {
      @extend %u-text;

      --fs: var(--font-size-sm);
      display: flex;
      list-style: none;
      padding: 0;
      margin: 0;
      align-items: center;
      gap: 0.125rem;

      @media (--mq-tablet) {
        color: var(--color-white);
        flex-direction: column;
        font-size: 1.25rem;
        gap: 0.25rem;
        width: 100%;
        padding: 0 1.5rem;
        align-items: stretch;
      }

      :global(li) {
        display: flex;
        align-items: center;
        position: relative;

        @media (--mq-tablet) {
          flex-direction: column;
          gap: 0;
          align-items: stretch;
        }

        &::after {
          display: none;
        }
      }

      :global(a) {
        text-decoration: none;
        position: relative;

        &::before {
          display: none;
        }
      }
    }
  }

  /* ── Dropdown trigger ── */
  .nav-parent {
    @extend %u-text;

    --fs: var(--font-size-sm);
    background: none;
    border: none;
    color: rgba(240, 240, 250, 0.72);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 0.3em;
    padding: 0.4rem 0.75rem;
    border-radius: 0.5rem;
    font-size: inherit;
    line-height: inherit;
    letter-spacing: inherit;
    position: relative;
    white-space: nowrap;
    transition: background 0.15s, color 0.15s;

    &:hover,
    &:focus-visible {
      background: rgba(255, 255, 255, 0.06);
      color: rgb(240, 240, 250);
    }

    @media (--mq-tablet) {
      font-size: 1.25rem;
      padding: 0.6rem 0.75rem;
      justify-content: space-between;
      width: 100%;
      color: rgba(240, 240, 250, 0.88);
      border-radius: 0.75rem;

      &:hover {
        background: rgba(255, 255, 255, 0.05);
      }
    }
  }

  .chevron {
    width: 0.85em;
    height: 0.85em;
    flex-shrink: 0;
    opacity: 0.45;
    transition: transform 0.25s var(--ease-out-cubic), opacity 0.15s;

    .has-dropdown:hover &,
    .has-dropdown.is-open & {
      opacity: 1;
    }

    .has-dropdown.is-open & {
      transform: rotate(180deg);
    }
  }

  /* ── Dropdown: activation ── */
  .has-dropdown {
    @media not (--mq-tablet) {
      &:hover .dropdown,
      &:focus-within .dropdown {
        opacity: 1;
        pointer-events: auto;
        transform: translateX(-50%) translateY(0);
      }

      &:hover .nav-parent,
      &:focus-within .nav-parent {
        background: rgba(255, 255, 255, 0.06);
        color: rgb(240, 240, 250);
      }
    }
  }

  /* ── Dropdown panel ── */
  .dropdown {
    @extend %u-text;

    @media not (--mq-tablet) {
      position: absolute;
      top: calc(100% + 0.75rem);
      left: 50%;
      transform: translateX(-50%) translateY(8px);
      opacity: 0;
      pointer-events: none;
      transition:
        opacity 0.18s ease,
        transform 0.18s var(--ease-out-cubic);

      background: rgba(9, 9, 20, 0.98);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-top: 2px solid rgb(var(--rgb-brand-2));
      border-radius: 0.875rem;
      padding: 0.375rem;
      min-width: 22rem;
      backdrop-filter: blur(36px);
      -webkit-backdrop-filter: blur(36px);
      box-shadow:
        0 0 0 1px rgba(0, 0, 0, 0.4),
        0 4px 8px rgba(0, 0, 0, 0.2),
        0 20px 60px rgba(0, 0, 0, 0.7),
        0 0 80px rgba(50, 170, 255, 0.04);

      /* Arrow notch pointing up */
      &::before {
        content: "";
        position: absolute;
        top: -5px;
        left: 50%;
        transform: translateX(-50%) rotate(45deg);
        width: 8px;
        height: 8px;
        background: rgb(var(--rgb-brand-2));
        clip-path: polygon(0 0, 100% 0, 0 100%);
      }
    }

    @media (--mq-tablet) {
      display: none;
      margin-top: 0.25rem;
      padding-bottom: 0.625rem;
      border-left: 2px solid rgba(50, 170, 255, 0.18);
      margin-left: 0.625rem;
      padding-left: 0.875rem;

      .has-dropdown.is-open & {
        display: block;
      }
    }
  }

  .dropdown-grid {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* ── Dropdown column & items ── */
  .dropdown-col {
    :global(ul) {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0 !important;
      font-size: inherit !important;
    }

    :global(li) {
      display: block !important;
      gap: 0 !important;

      &::after {
        display: none !important;
      }
    }

    :global(a) {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      padding: 0.55rem 0.625rem;
      border-radius: 0.625rem;
      text-decoration: none;
      transition: background 0.12s ease, color 0.12s ease;
      color: rgba(240, 240, 250, 0.6);

      &::before {
        display: none !important;
      }

      &:hover,
      &:focus {
        background: rgba(50, 170, 255, 0.07);
        color: rgba(240, 240, 250, 0.95);

        .child-icon-wrap {
          background: rgba(50, 170, 255, 0.13);
          border-color: rgba(50, 170, 255, 0.28);
        }

        .child-icon {
          transform: scale(1.08);
        }

        .child-title {
          color: rgb(240, 240, 250);
        }

        .child-desc {
          color: rgba(240, 240, 250, 0.45);
        }
      }

      @media (--mq-tablet) {
        padding: 0.5rem 0;
        border-radius: 0;
        gap: 0.625rem;
        color: rgba(240, 240, 250, 0.75);
      }
    }
  }

  .group-label {
    display: none;

    @media (--mq-tablet) {
      display: block;
      font-size: 0.63rem;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: rgba(50, 170, 255, 0.55);
      margin: 0.625rem 0 0.375rem;
      padding: 0;
    }
  }

  .child-icon-wrap {
    width: 2.125rem;
    height: 2.125rem;
    border-radius: 0.5625rem;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.07);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.12s ease, border-color 0.12s ease;

    @media (--mq-tablet) {
      width: 1.875rem;
      height: 1.875rem;
    }
  }

  .child-icon {
    font-size: 1rem;
    line-height: 1;
    transition: transform 0.12s ease;
  }

  .child-text {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    min-width: 0;
  }

  .child-title {
    font-size: 0.84rem;
    font-weight: 500;
    color: rgba(240, 240, 250, 0.88);
    line-height: 1.2;
    transition: color 0.12s ease;
    white-space: nowrap;
  }

  .child-desc {
    font-size: 0.695rem;
    color: rgba(240, 240, 250, 0.3);
    line-height: 1.3;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    transition: color 0.12s ease;

    @media (--mq-tablet) {
      display: none;
    }
  }

  /* ── Buttons area ── */
  .buttons {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    z-index: 2;
    flex-shrink: 0;

    @media (--mq-tablet) {
      gap: 0.75rem;
    }
  }

  .login {
    @extend %u-text;

    --fs: var(--font-size-sm);
    position: relative;
    color: rgba(240, 240, 250, 0.65);
    transition: color 0.2s;

    &:hover,
    &:focus {
      color: rgb(240, 240, 250);
    }

    @media (--mq-phone) {
      display: none;
    }
  }

  .lang-switch {
    @extend %u-text;

    --fs: var(--font-size-sm);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    padding: 0.25em 0.65em;
    border: 1px solid rgba(50, 170, 255, 0.35);
    border-radius: 999px;
    color: rgba(240, 240, 250, 0.75);
    text-decoration: none;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    white-space: nowrap;

    &:hover,
    &:focus {
      color: rgb(240, 240, 250);
      border-color: rgba(50, 170, 255, 0.7);
      background: rgba(50, 170, 255, 0.08);
    }

    @media (--mq-phone) {
      display: none;
    }
  }

  /* ── Hamburger toggle ── */
  .toggle {
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    align-self: normal;
    align-items: center;
    display: none;
    z-index: 2;
    color: var(--color-brand-1);
    transition: color 0.3s var(--ease-out-expo);

    :global(.has-no-bg &) {
      color: var(--color-brand-3);
    }

    :global(body.is-nav-opened &),
    :global(body.is-nav-small) & {
      color: var(--color-brand-1);
    }

    @media (--mq-tablet) {
      display: flex;
    }

    > span:last-child {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      height: 1.375rem;
      width: 2rem;

      span {
        display: flex;
        width: 100%;
        height: 3px;
        background: currentcolor;
        border-radius: 10px;
        transition: transform 0.2s var(--ease-out-cubic);
        transform: translateZ(0);

        &:nth-child(2) {
          transition-property: opacity;
        }
      }
    }

    :global(body.is-nav-opened) & {
      color: var(--color-brand-1);

      > span {
        span {
          &:first-child {
            transform: translateY(calc(0.6875rem - 1.5px)) rotate(45deg);
          }

          &:nth-child(2) {
            opacity: 0;
          }

          &:last-child {
            transform: translateY(calc(-0.6875rem + 1.5px)) rotate(-45deg);
          }
        }
      }
    }
  }
</style>

<script>
  import { addScrollObserver } from "../utils/observers";

  const heroSelectors = ["sy-hero-home"];

  class Header extends HTMLElement {
    smallThreshold = 100;
    hiddenThreshold = 200;
    toggleEl = this.querySelector(".toggle")!;
    hero = document.querySelector(heroSelectors.join(","));
    prevY = -1;

    constructor() {
      super();

      addScrollObserver(this);

      this.toggleEl.addEventListener("click", this.toggleNav);

      // Dropdown toggles (mobile click / desktop keyboard)
      this.querySelectorAll<HTMLButtonElement>(".nav-parent").forEach((btn) => {
        btn.addEventListener("click", () => {
          const li = btn.closest(".has-dropdown")!;
          const isOpen = li.classList.contains("is-open");
          this.closeAllDropdowns();
          if (!isOpen) {
            li.classList.add("is-open");
            btn.setAttribute("aria-expanded", "true");
            li.querySelector(".dropdown")?.setAttribute("aria-hidden", "false");
          }
        });
      });

      // Close on outside click
      document.addEventListener("click", (e) => {
        if (!(e.target as Element).closest(".has-dropdown")) {
          this.closeAllDropdowns();
        }
      });

      this.onResize();
      this.onScroll(window.scrollY);
    }

    onScroll(y: number) {
      if (y < 0) return;

      const diff = y - this.prevY;
      const isDown = diff > 0;
      const threshold = 5;

      const classList = document.body.classList;

      const shouldBeSmall = y > this.smallThreshold;
      const isSmall = classList.contains("is-nav-small");

      if (shouldBeSmall !== isSmall) {
        classList.toggle("is-nav-small", shouldBeSmall);
      }

      if (Math.abs(diff) > threshold || y <= 0) {
        const shouldBeHidden = y > this.hiddenThreshold && isDown;
        const isHidden = classList.contains("is-nav-hidden");

        if (shouldBeHidden !== isHidden) {
          classList.toggle("is-nav-hidden", shouldBeHidden);
        }
      }

      this.prevY = y;
    }

    closeAllDropdowns() {
      this.querySelectorAll(".has-dropdown.is-open").forEach((el) => {
        el.classList.remove("is-open");
        el.querySelector(".nav-parent")?.setAttribute("aria-expanded", "false");
        el.querySelector(".dropdown")?.setAttribute("aria-hidden", "true");
      });
    }

    toggleNav = () => {
      document.body.classList.toggle("is-nav-opened");
    };

    onResize() {
      const hero = this.hero;
      const bcr = this.getBoundingClientRect();
      const heroBcr = hero && hero.getBoundingClientRect();

      this.smallThreshold = heroBcr ? heroBcr.height - bcr.height : bcr.height;
    }
  }

  customElements.define("sy-head", Header);
</script>
