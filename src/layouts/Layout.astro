---
import { Font } from "astro:assets";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SmoothScroll from "../components/SmoothScroll.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getNavLinks } from "../i18n/navLinks";
import { getAlternates } from "../i18n/routes";
import "../styles/global.css";
import logoImg from "../assets/img/logo.webp";

const { title, description } = Astro.props;

// ── Language detection ────────────────────────────────────────────────────────
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEn = lang === 'en';

// ── Nav links (language-aware) ────────────────────────────────────────────────
const { main: links, legalLinks, ctaLink, scheduleLink } = getNavLinks(lang);

// ── SEO base URLs ─────────────────────────────────────────────────────────────
const siteUrl = (Astro.site?.href ?? "https://sonmyd.co/").replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://sonmyd.co").href;

// ── hreflang alternates ───────────────────────────────────────────────────────
const alternates = getAlternates(Astro.url.pathname, siteUrl);

// ── Language switcher for header ──────────────────────────────────────────────
const langSwitcher = alternates
  ? { url: isEn ? alternates.es : alternates.en, label: isEn ? 'Español' : 'English' }
  : undefined;

// ── Descriptions ─────────────────────────────────────────────────────────────
const defaultDescription = isEn
  ? "Sonmyd: AI automation platform. Google Calendar scheduling, WhatsApp chatbots, website creation and business process automation by Miguel Zuluaga."
  : "Sonmyd: plataforma de automatización con IA. Agendamiento con Google Calendar, chatbots en WhatsApp, creación de sitios web y automatización de procesos empresariales.";

const metaDescription = description || defaultDescription;

// ── OG locale / keywords ─────────────────────────────────────────────────────
const ogLocale = isEn ? "en_US" : "es_CO";
const metaKeywords = isEn
  ? "AI classes, AI mentorship, learn AI, machine learning, Python AI, LLMs, prompt engineering, generative AI, online AI classes, Sonmyd, Miguel Zuluaga"
  : "clases inteligencia artificial, mentoría IA, aprender IA, machine learning, Python IA, LLMs, prompt engineering, IA generativa, clases online IA, Sonmyd, Miguel Zuluaga";

// ── JSON-LD Schemas (language-aware) ─────────────────────────────────────────
const schemaWebSite = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}#website`,
  name: "Sonmyd",
  url: siteUrl,
  description: isEn
    ? "1-on-1 AI classes with Miguel Zuluaga. From fundamentals to advanced level."
    : "Clases 1 a 1 de Inteligencia Artificial con Miguel Zuluaga. Desde fundamentos hasta nivel avanzado.",
  inLanguage: isEn ? "en" : "es",
  author: { "@id": `${siteUrl}#person` },
};

const schemaPerson = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteUrl}#person`,
  name: "Miguel Zuluaga",
  alternateName: "Sonmyd",
  url: siteUrl,
  image: `${siteUrl}/foto_miguel.png`,
  jobTitle: isEn ? "Artificial Intelligence Expert" : "Experto en Inteligencia Artificial",
  description: isEn
    ? "AI applied specialist: language models, computer vision, automation and machine learning."
    : "Especialista en IA aplicada: modelos de lenguaje, visión computacional, automatización y aprendizaje automático.",
  sameAs: ["https://twitter.com/sonmyd"],
  knowsAbout: isEn
    ? ["Artificial Intelligence", "Machine Learning", "Deep Learning", "Large Language Models (LLMs)", "Generative AI", "Prompt Engineering", "Python for AI", "Computer Vision", "RAG and Embeddings", "AI Automation"]
    : ["Inteligencia Artificial", "Machine Learning", "Deep Learning", "Modelos de Lenguaje (LLMs)", "IA Generativa", "Prompt Engineering", "Python para IA", "Computer Vision", "RAG y Embeddings", "Automatización con IA"],
};

const schemaService = {
  "@context": "https://schema.org",
  "@type": "Service",
  name: isEn ? "Personalized AI Classes" : "Clases personalizadas de Inteligencia Artificial",
  url: siteUrl,
  description: isEn
    ? "1-on-1 AI mentorship: Machine Learning, LLMs, Python, Prompt Engineering and more. From beginners to advanced level."
    : "Mentoría 1 a 1 en IA: Machine Learning, LLMs, Python, Prompt Engineering y más. Desde principiantes hasta nivel avanzado.",
  serviceType: isEn ? "Artificial Intelligence Education" : "Educación en Inteligencia Artificial",
  provider: { "@id": `${siteUrl}#person` },
  areaServed: {
    "@type": "Place",
    name: isEn ? "Online — Latin America, Spain & United States" : "Online — América Latina y España",
  },
  availableChannel: {
    "@type": "ServiceChannel",
    serviceType: "Online",
    availableLanguage: isEn
      ? [{ "@type": "Language", name: "English" }, { "@type": "Language", name: "Spanish" }]
      : { "@type": "Language", name: "Spanish" },
  },
  offers: [
    {
      "@type": "Offer",
      name: isEn ? "Individual Session" : "Clase Individual",
      price: "25",
      priceCurrency: "USD",
      description: isEn
        ? "60-minute session with support material and recording included."
        : "Sesión de 60 minutos con material de apoyo y grabación incluida.",
    },
    {
      "@type": "Offer",
      name: isEn ? "Intensive Package" : "Paquete Intensivo",
      price: "220",
      priceCurrency: "USD",
      description: isEn
        ? "10 hours of classes with continuous follow-up and a real portfolio project."
        : "10 horas de clase con seguimiento continuo y proyecto real de portafolio.",
    },
  ],
};
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-KNZPFWXB");
    </script>
    <!-- End Google Tag Manager -->

    <!-- Primary meta -->
    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <meta name="author" content="Miguel Zuluaga" />
    <meta name="keywords" content={metaKeywords} />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#07070f" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang alternates (SEO multilingual) -->
    {alternates && (
      <>
        <link rel="alternate" hreflang="es" href={alternates.es} />
        <link rel="alternate" hreflang="en" href={alternates.en} />
        <link rel="alternate" hreflang="x-default" href={alternates.es} />
      </>
    )}

    <!-- Favicon -->
    <link rel="icon" type="image/webp" href={logoImg.src} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Sonmyd" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:locale" content={ogLocale} />
    {alternates && (
      isEn
        ? <meta property="og:locale:alternate" content="es_CO" />
        : <meta property="og:locale:alternate" content="en_US" />
    )}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={isEn ? "Sonmyd — Personalized AI Classes with Miguel Zuluaga" : "Sonmyd — Clases de IA Personalizadas con Miguel Zuluaga"} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@sonmyd" />
    <meta name="twitter:site" content="@sonmyd" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />

    <!-- JSON-LD: WebSite -->
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schemaWebSite)}</script>`} />
    <!-- JSON-LD: Person -->
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schemaPerson)}</script>`} />
    <!-- JSON-LD: Service -->
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schemaService)}</script>`} />

    <!-- Head slot para schemas adicionales por página -->
    <slot name="head" />

    <Font cssVariable="--font-roboto-slab" preload />
    <Font cssVariable="--font-inter" preload />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-KNZPFWXB"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->
    <a href="#main" class="skip-link">{t("accessibility.skip-to-content")}</a>
    <Header
      logoUrl={isEn ? "/en" : "/"}
      logoAlt="Sonmyd"
      links={links}
      link1={scheduleLink}
      link2={ctaLink}
      langSwitcher={langSwitcher}
    />
    <main id="main">
      <slot />
    </main>
    <Footer
      logoUrl={isEn ? "/en" : "/"}
      logoAlt="Sonmyd"
      links={links.flatMap(l => l.groups?.flatMap(g => g.items) ?? [{ title: l.title, url: l.url ?? '/' }])}
      legalLinks={legalLinks}
    />
    <SmoothScroll />
  </body>
</html>

<style>
  .skip-link {
    background: var(--color-brand-1);
    left: 0;
    right: 0;
    margin: auto;
    width: min-content;
    white-space: nowrap;
    padding: 0.5rem;
    position: absolute;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 100;
  }

  .skip-link:focus {
    transform: translateY(0%);
  }
</style>

<script>
  import "../utils/reveals";
</script>
