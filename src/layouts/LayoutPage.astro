---
import { Font } from "astro:assets";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SmoothScroll from "../components/SmoothScroll.astro";
import { getLangFromUrl, useTranslations } from "../i18n/utils";
import { getNavLinks } from "../i18n/navLinks";
import { getAlternates } from "../i18n/routes";
import "../styles/global.css";
import logoImg from "../assets/img/logo.webp";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

// ── Language detection ────────────────────────────────────────────────────────
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isEn = lang === 'en';

// ── Nav links (language-aware) ────────────────────────────────────────────────
const { main: navLinks, legalLinks, ctaLink } = getNavLinks(lang);

// ── SEO base URLs ─────────────────────────────────────────────────────────────
const siteUrl = (Astro.site?.href ?? "https://sonmyd.co/").replace(/\/$/, '');
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? "https://sonmyd.co").href;

// ── hreflang alternates ───────────────────────────────────────────────────────
const alternates = getAlternates(Astro.url.pathname, siteUrl);

// ── Language switcher for header ──────────────────────────────────────────────
const langSwitcher = alternates
  ? { url: isEn ? alternates.es : alternates.en, label: isEn ? 'Español' : 'English' }
  : undefined;

// ── Descriptions ─────────────────────────────────────────────────────────────
const defaultDescription = isEn
  ? "Learn AI with 1-on-1 mentorship: Machine Learning, LLMs, Python for AI, Prompt Engineering and more. Classes with Miguel Zuluaga from fundamentals to expert level."
  : "Aprende IA con mentoría 1 a 1: Machine Learning, LLMs, Python para IA, Prompt Engineering y más. Clases con Miguel Zuluaga desde fundamentos hasta nivel experto.";

const metaDescription = description || defaultDescription;

const ogLocale = isEn ? "en_US" : "es_CO";
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!-- Google Tag Manager -->
    <script>
      (function (w, d, s, l, i) {
        w[l] = w[l] || [];
        w[l].push({ "gtm.start": new Date().getTime(), event: "gtm.js" });
        var f = d.getElementsByTagName(s)[0],
          j = d.createElement(s),
          dl = l != "dataLayer" ? "&l=" + l : "";
        j.async = true;
        j.src = "https://www.googletagmanager.com/gtm.js?id=" + i + dl;
        f.parentNode.insertBefore(j, f);
      })(window, document, "script", "dataLayer", "GTM-KNZPFWXB");
    </script>
    <!-- End Google Tag Manager -->

    <title>{title}</title>
    <meta name="description" content={metaDescription} />
    <meta name="author" content="Miguel Zuluaga" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#07070f" />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- hreflang alternates (SEO multilingual) -->
    {alternates && (
      <>
        <link rel="alternate" hreflang="es" href={alternates.es} />
        <link rel="alternate" hreflang="en" href={alternates.en} />
        <link rel="alternate" hreflang="x-default" href={alternates.es} />
      </>
    )}

    <link rel="icon" type="image/webp" href={logoImg.src} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="sonmyd" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:locale" content={ogLocale} />
    {alternates && (
      isEn
        ? <meta property="og:locale:alternate" content="es_CO" />
        : <meta property="og:locale:alternate" content="en_US" />
    )}
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={`${siteUrl}/og-image.png`} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:creator" content="@sonmyd" />
    <meta name="twitter:site" content="@sonmyd" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={`${siteUrl}/og-image.png`} />

    <!-- Slot for extra head content per page -->
    <slot name="head" />

    <Font cssVariable="--font-roboto-slab" preload />
    <Font cssVariable="--font-inter" preload />
  </head>
  <body>
    <!-- Google Tag Manager (noscript) -->
    <noscript
      ><iframe
        src="https://www.googletagmanager.com/ns.html?id=GTM-KNZPFWXB"
        height="0"
        width="0"
        style="display:none;visibility:hidden"></iframe></noscript
    >
    <!-- End Google Tag Manager (noscript) -->

    <a href="#main" class="skip-link">{t("accessibility.skip-to-content")}</a>
    <Header
      logoUrl={isEn ? "/en" : "/"}
      logoAlt="sonmyd"
      links={navLinks}
      link2={ctaLink}
      langSwitcher={langSwitcher}
    />
    <main id="main">
      <slot />
    </main>
    <Footer
      logoUrl={isEn ? "/en" : "/"}
      logoAlt="sonmyd"
      links={navLinks.flatMap(l => l.groups?.flatMap(g => g.items) ?? [{ title: l.title, url: l.url ?? '/' }])}
      legalLinks={legalLinks}
    />
    <SmoothScroll />
  </body>
</html>

<style>
  body {
    background: var(--color-bg);
  }

  .skip-link {
    background: var(--color-brand-1);
    left: 0;
    right: 0;
    margin: auto;
    width: min-content;
    white-space: nowrap;
    padding: 0.5rem;
    position: absolute;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
    z-index: 100;
  }

  .skip-link:focus {
    transform: translateY(0%);
  }
</style>

<script>
  import "../utils/reveals";
</script>
