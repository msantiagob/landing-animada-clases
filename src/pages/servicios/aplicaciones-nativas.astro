---
import LayoutPage from "../../layouts/LayoutPage.astro";
import { getLangFromUrl } from "../../i18n/utils";
import { getServicesPath } from "../../i18n/paths";

const lang = getLangFromUrl(Astro.url);
const servicesHref = getServicesPath(lang);

const WA = "https://wa.me/573106041144?text=Hola%2C+me+interesa+el+servicio+de+aplicaciones+nativas.";
---

<LayoutPage
  title="Aplicaciones Nativas | sonmyd — Miguel Zuluaga"
  description="Desarrollo de aplicaciones móviles y de escritorio nativas. iOS, Android y cross-platform con React Native y Tauri para rendimiento máximo."
>
  <div class="page">
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="u-container">
        <a href={servicesHref} class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" /></svg>
          {lang === "en" ? "Services" : "Servicios"}
        </a>
        <div class="badge u-text">📱 iOS · Android · Desktop</div>
        <h1 class="u-heading hero-title" data-sy-reveal="words">Aplicaciones<br />Nativas</h1>
        <p class="u-text hero-sub" data-sy-reveal="lines">
          Apps móviles y de escritorio que se sienten nativas: fluidas, rápidas y con acceso completo al hardware del dispositivo. Una base de código, múltiples plataformas.
        </p>
        <a href={WA} target="_blank" rel="noopener noreferrer" class="cta-btn">
          Hablemos de tu app
        </a>
      </div>
    </section>

    <section class="section u-container">
      <h2 class="u-heading sec-title" data-sy-reveal="words">¿Qué construimos?</h2>
      <div class="cards">
        {[
          { n: "01", t: "Apps móviles (iOS & Android)", d: "Aplicaciones cross-platform con React Native o Expo. Una sola base de código con experiencia nativa en ambas plataformas." },
          { n: "02", t: "Apps de escritorio", d: "Aplicaciones para macOS, Windows y Linux con Tauri (Rust + Web) o Electron. Rápidas, ligeras y con acceso al sistema." },
          { n: "03", t: "Apps con IA embebida", d: "Aplicaciones que corren modelos de IA localmente (on-device): reconocimiento de voz, visión, procesamiento de texto sin internet." },
          { n: "04", t: "Publicación en stores", d: "Configuración y envío a App Store (Apple) y Google Play. Firma, certificados, revisión de políticas y actualizaciones OTA." },
        ].map((c) => (
          <div class="card">
            <span class="card-n">{c.n}</span>
            <h3 class="u-text card-title">{c.t}</h3>
            <p class="u-text card-desc">{c.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section section--alt">
      <div class="u-container">
        <h2 class="u-heading sec-title" data-sy-reveal="words">Stack tecnológico</h2>
        <ul class="topics-list u-text">
          <li>React Native / Expo</li>
          <li>Tauri (desktop)</li>
          <li>TypeScript</li>
          <li>Swift (iOS nativo)</li>
          <li>Kotlin (Android nativo)</li>
          <li>Core ML / TensorFlow Lite</li>
          <li>SQLite / Realm (local DB)</li>
          <li>Push notifications (FCM/APNs)</li>
        </ul>
      </div>
    </section>

    <section class="section u-container">
      <h2 class="u-heading sec-title" data-sy-reveal="words">¿Para quién es?</h2>
      <ul class="for-list u-text">
        <li>Startups que necesitan una app móvil funcional rápido y con presupuesto controlado.</li>
        <li>Empresas que quieren llevar su herramienta web a iOS y Android.</li>
        <li>Proyectos que requieren procesamiento de IA directamente en el dispositivo.</li>
        <li>Negocios que necesitan una app de escritorio para su equipo interno.</li>
      </ul>
    </section>

    <section class="section cta-sec u-container">
      <h2 class="u-heading cta-title" data-sy-reveal="words">¿Tu idea lista para ser una app?</h2>
      <p class="u-text cta-text">Cuéntame qué quieres construir y te doy una propuesta honesta de tiempo y alcance.</p>
      <a href={WA} target="_blank" rel="noopener noreferrer" class="cta-btn">
        Hablemos por WhatsApp →
      </a>
    </section>
  </div>
</LayoutPage>

<style>
  @import "../../styles/_service-page.css";
</style>
