---
import LayoutPage from "../layouts/LayoutPage.astro";
import { getBookableDates, formatDate, WEEKLY_SLOTS } from "../lib/schedule";

const dates = getBookableDates(28);
const slotsJson = JSON.stringify(WEEKLY_SLOTS);
const datesJson = JSON.stringify(dates);
---

<LayoutPage
  title="Agendar reunión | Sonmyd — Miguel Zuluaga"
  description="Agenda una reunión con Miguel Zuluaga de Sonmyd. Sesión de diagnóstico gratuita para evaluar tu proyecto de automatización con IA."
>
  <div class="book-page">

    <!-- AUTH GATE -->
    <div id="auth-gate" class="auth-gate">
      <div class="auth-card">
        <div class="auth-card__left">
          <div class="auth-avatar">MZ</div>
          <div class="auth-card__info">
            <span class="auth-badge">Sesión gratuita</span>
            <h1 class="auth-name">Miguel Zuluaga</h1>
            <p class="auth-role">Fundador de Sonmyd · Experto en IA</p>
            <ul class="auth-meta">
              <li>
                <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 4.5v3.75l2.25 2.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
                30 minutos
              </li>
              <li>
                <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="1.5" y="3.5" width="13" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M1.5 7h13" stroke="currentColor" stroke-width="1.5"/></svg>
                Google Meet / Zoom
              </li>
              <li>
                <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/><path d="M8 1.5C8 1.5 5.5 5 5.5 8s2.5 6.5 2.5 6.5M8 1.5C8 1.5 10.5 5 10.5 8S8 14.5 8 14.5M1.5 8h13" stroke="currentColor" stroke-width="1.5"/></svg>
                Hora Colombia (UTC-5)
              </li>
            </ul>
          </div>
        </div>
        <div class="auth-card__right">
          <p class="auth-title">Reserva tu espacio</p>
          <p class="auth-sub">Primera sesión de diagnóstico sin costo. Analizamos tu proyecto e identificamos cómo automatizarlo.</p>
          <button id="btn-google-login" class="btn-google">
            <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
              <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
              <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
              <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
              <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
            </svg>
            Continuar con Google
          </button>
          <p class="auth-disclaimer">Al continuar aceptas nuestra <a href="/privacidad">Política de Privacidad</a>.</p>
        </div>
      </div>
    </div>

    <!-- BOOKING WIDGET (oculto hasta auth) -->
    <div id="booking-widget" class="booking-widget" style="display:none">
      <div class="book-wrap">

        <!-- Left panel -->
        <aside class="book-info">
          <div class="book-info__top">
            <div class="book-avatar">MZ</div>
            <div>
              <p class="book-info__org">Sonmyd</p>
              <h1 class="book-info__name">Miguel Zuluaga</h1>
            </div>
          </div>

          <div class="book-info__badge">Sesión de diagnóstico · Gratis</div>

          <ul class="book-info__meta">
            <li>
              <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1.5"/><path d="M8 4.5v3.75l2.25 2.25" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
              30 minutos
            </li>
            <li>
              <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><rect x="1.5" y="3.5" width="13" height="10" rx="1.5" stroke="currentColor" stroke-width="1.5"/><path d="M1.5 7h13" stroke="currentColor" stroke-width="1.5"/></svg>
              Google Meet / Zoom
            </li>
            <li>
              <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.5"/><path d="M8 1.5C8 1.5 5.5 5 5.5 8s2.5 6.5 2.5 6.5M8 1.5C8 1.5 10.5 5 10.5 8S8 14.5 8 14.5M1.5 8h13" stroke="currentColor" stroke-width="1.5"/></svg>
              Hora Colombia (UTC-5)
            </li>
          </ul>

          <p class="book-info__desc">
            Analizamos tu proyecto, identificamos qué automatizar y diseñamos un plan concreto. Sin compromiso.
          </p>

          <div class="book-info__user">
            <img id="user-photo" src="" alt="" class="user-photo" />
            <span id="user-name" class="user-name-text"></span>
            <button id="btn-logout" class="btn-logout">Salir</button>
          </div>
        </aside>

        <!-- Divider -->
        <div class="book-divider" aria-hidden="true"></div>

        <!-- Right panel: steps -->
        <div class="book-picker">

          <!-- Step 1: date -->
          <div id="step-date" class="step">
            <h2 class="step__title">Selecciona una fecha</h2>
            <div class="date-strip" id="date-strip"></div>
          </div>

          <!-- Step 2: time -->
          <div id="step-time" class="step" style="display:none">
            <div class="step__header">
              <button id="btn-back-date" class="btn-back">
                <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Volver
              </button>
              <h2 class="step__title">Elige un horario</h2>
            </div>
            <div id="slots-grid" class="slots-grid"></div>
          </div>

          <!-- Step 3: confirm -->
          <div id="step-confirm" class="step" style="display:none">
            <div class="step__header">
              <button id="btn-back-time" class="btn-back">
                <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                Volver
              </button>
              <h2 class="step__title">Confirma tu reserva</h2>
            </div>
            <div class="confirm-card">
              <div class="confirm-row">
                <span class="confirm-icon">📅</span>
                <div><span class="confirm-label">Fecha</span><span id="confirm-date-text" class="confirm-value"></span></div>
              </div>
              <div class="confirm-row">
                <span class="confirm-icon">🕐</span>
                <div><span class="confirm-label">Hora</span><span id="confirm-time-text" class="confirm-value"></span></div>
              </div>
              <div class="confirm-row">
                <span class="confirm-icon">⏱</span>
                <div><span class="confirm-label">Duración</span><span class="confirm-value">30 minutos</span></div>
              </div>
            </div>
            <label class="notes-label">
              ¿De qué quieres hablar?
              <span class="notes-optional">Opcional</span>
              <textarea id="notes-input" class="notes-input" rows="3" placeholder="Ej: Quiero automatizar el agendamiento de mi clínica con Google Calendar..."></textarea>
            </label>
            <button id="btn-confirm" class="btn-confirm">Confirmar reserva</button>
          </div>

          <!-- Step 4: success -->
          <div id="step-success" class="step step--success" style="display:none">
            <div class="success-check">
              <svg viewBox="0 0 48 48" fill="none" aria-hidden="true">
                <circle cx="24" cy="24" r="23" stroke="rgb(52,211,153)" stroke-width="2"/>
                <path d="M14 24l7 7 13-14" stroke="rgb(52,211,153)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h2 class="success-title">¡Reserva confirmada!</h2>
            <p class="success-text" id="success-text"></p>
            <p class="success-sub">Recibirás confirmación en tu correo. Miguel se pondrá en contacto pronto.</p>
            <a href="/" class="btn-confirm btn-confirm--outline">Volver al inicio</a>
          </div>

        </div><!-- /book-picker -->
      </div><!-- /book-wrap -->
    </div><!-- /booking-widget -->

  </div>
</LayoutPage>

<!-- Exponer datos del servidor como variables globales (inline — no módulo) -->
<script define:vars={{ slotsJson, datesJson }} is:inline>
  window.__BOOK_SLOTS__ = JSON.parse(slotsJson);
  window.__BOOK_DATES__ = JSON.parse(datesJson);
</script>

<!-- Lógica principal — módulo procesado por Vite, soporta import() -->
<script>
  import { auth, db, googleProvider } from '../lib/firebase.ts';
  import { onAuthStateChanged, signInWithPopup, signOut } from 'firebase/auth';
  import { collection, addDoc, serverTimestamp, query, where, getDocs } from 'firebase/firestore';

  const WEEKLY_SLOTS: Record<number, string[]> = (window as any).__BOOK_SLOTS__;
  const DATES: string[] = (window as any).__BOOK_DATES__;

  let selectedDate = '';
  let selectedTime = '';

  // ── Auth ──────────────────────────────────────────────────────────────────
  onAuthStateChanged(auth, (user) => {
    if (user) {
      showWidget(user);
    } else {
      const gate = document.getElementById('auth-gate');
      const widget = document.getElementById('booking-widget');
      if (gate) gate.style.display = '';
      if (widget) widget.style.display = 'none';
    }
  });

  document.getElementById('btn-google-login')?.addEventListener('click', async () => {
    try {
      await signInWithPopup(auth, googleProvider);
    } catch (e: any) {
      if (e?.code !== 'auth/popup-closed-by-user') console.error(e);
    }
  });

  document.getElementById('btn-logout')?.addEventListener('click', () => {
    signOut(auth);
  });

  function showWidget(user) {
    document.getElementById('auth-gate').style.display = 'none';
    document.getElementById('booking-widget').style.display = '';
    document.getElementById('user-name').textContent = user.displayName ?? user.email;
    const photo = document.getElementById('user-photo');
    if (user.photoURL) { photo.src = user.photoURL; photo.alt = user.displayName; }
    else { photo.style.display = 'none'; }
    buildDateStrip();
  }

  // ── Date strip ────────────────────────────────────────────────────────────
  function buildDateStrip() {
    const strip = document.getElementById('date-strip');
    strip.innerHTML = '';
    DATES.forEach(iso => {
      const [y, m, d] = iso.split('-').map(Number);
      const date = new Date(y, m - 1, d);
      const dow = date.getDay();
      const days = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];
      const months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];

      const btn = document.createElement('button');
      btn.className = 'date-btn';
      btn.dataset.iso = iso;
      btn.innerHTML = `<span class="date-btn__dow">${days[dow]}</span><span class="date-btn__day">${d}</span><span class="date-btn__month">${months[m-1]}</span>`;
      btn.addEventListener('click', () => selectDate(iso, btn));
      strip.appendChild(btn);
    });
  }

  function selectDate(iso, btn) {
    selectedDate = iso;
    document.querySelectorAll('.date-btn').forEach(b => b.classList.remove('is-selected'));
    btn.classList.add('is-selected');
    showStep('time');
    loadSlots(iso);
  }

  // ── Time slots ────────────────────────────────────────────────────────────
  async function loadSlots(iso: string) {
    const grid = document.getElementById('slots-grid')!;
    grid.innerHTML = '<p style="color:rgba(255,255,255,0.4);font-size:0.85rem">Cargando disponibilidad...</p>';

    const q = query(
      collection(db, 'bookings'),
      where('date', '==', iso),
      where('status', '!=', 'cancelled')
    );
    const snap = await getDocs(q);
    const booked = new Set(snap.docs.map(d => d.data().time));

    const [y, m, day] = iso.split('-').map(Number);
    const dow = new Date(y, m - 1, day).getDay();
    const slots = WEEKLY_SLOTS[dow] ?? [];

    grid.innerHTML = '';
    slots.forEach(time => {
      const taken = booked.has(time);
      const btn = document.createElement('button');
      btn.className = 'slot-btn' + (taken ? ' is-taken' : '');
      btn.textContent = time + ' COT';
      btn.disabled = taken;
      btn.addEventListener('click', () => selectTime(time, btn));
      grid.appendChild(btn);
    });
  }

  function selectTime(time, btn) {
    selectedTime = time;
    document.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('is-selected'));
    btn.classList.add('is-selected');
    fillConfirm();
    showStep('confirm');
  }

  // ── Confirm ───────────────────────────────────────────────────────────────
  function fillConfirm() {
    const [y, m, d] = selectedDate.split('-').map(Number);
    const date = new Date(y, m - 1, d);
    const fmt = date.toLocaleDateString('es-CO', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
    document.getElementById('confirm-date-text').textContent = fmt.charAt(0).toUpperCase() + fmt.slice(1);
    document.getElementById('confirm-time-text').textContent = selectedTime + ' (Hora Colombia)';
  }

  document.getElementById('btn-back-date')?.addEventListener('click', () => showStep('date'));
  document.getElementById('btn-back-time')?.addEventListener('click', () => showStep('time'));
  document.getElementById('btn-confirm')?.addEventListener('click', confirmBooking);

  async function confirmBooking() {
    const user = auth.currentUser;
    if (!user) return;

    const btn = document.getElementById('btn-confirm');
    btn.disabled = true;
    btn.textContent = 'Guardando...';

    try {
      // Verificar que el slot siga disponible
      const slotKey = `${selectedDate}_${selectedTime}`;
      const q = query(
        collection(db, 'bookings'),
        where('slotKey', '==', slotKey),
        where('status', '!=', 'cancelled')
      );
      const existing = await getDocs(q);
      if (!existing.empty) {
        alert('Este horario acaba de ser reservado por otra persona. Por favor elige otro.');
        showStep('time');
        loadSlots(selectedDate);
        return;
      }

      const notes = document.getElementById('notes-input').value.trim();
      await addDoc(collection(db, 'bookings'), {
        userId:    user.uid,
        userEmail: user.email,
        userName:  user.displayName ?? user.email,
        userPhoto: user.photoURL ?? '',
        date:      selectedDate,
        time:      selectedTime,
        slotKey,
        status:    'pending',
        lang:      'es',
        notes,
        createdAt: serverTimestamp(),
      });

      const [y, m, d] = selectedDate.split('-').map(Number);
      const dateObj = new Date(y, m - 1, d);
      const fmt = dateObj.toLocaleDateString('es-CO', { weekday:'long', day:'numeric', month:'long' });
      document.getElementById('success-text').textContent =
        `Tu reunión del ${fmt} a las ${selectedTime} COT está confirmada.`;
      showStep('success');

    } catch (e) {
      console.error(e);
      alert('Ocurrió un error. Inténtalo de nuevo.');
      btn.disabled = false;
      btn.textContent = 'Confirmar reserva';
    }
  }

  // ── Step navigation ───────────────────────────────────────────────────────
  function showStep(name) {
    ['date','time','confirm','success'].forEach(s => {
      document.getElementById(`step-${s}`).style.display = s === name ? '' : 'none';
    });
  }
</script>

<style>
  /* ── Page shell ── */
  .book-page {
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* ════════════════════════════════════════
     AUTH GATE
  ════════════════════════════════════════ */
  .auth-gate {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 1.5rem 3rem;
  }

  .auth-card {
    display: flex;
    background: rgba(13, 13, 26, 0.9);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 1.5rem;
    overflow: hidden;
    max-width: 56rem;
    width: 100%;
    box-shadow: 0 32px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(0,0,0,0.3);

    @media (max-width: 680px) {
      flex-direction: column;
    }
  }

  .auth-card__left {
    padding: 2.5rem 2rem;
    background: rgba(50,170,255,0.04);
    border-right: 1px solid rgba(255,255,255,0.07);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    min-width: 20rem;

    @media (max-width: 680px) {
      border-right: none;
      border-bottom: 1px solid rgba(255,255,255,0.07);
      min-width: 0;
      flex-direction: row;
      align-items: flex-start;
      gap: 1rem;
      padding: 1.5rem;
    }
  }

  .auth-avatar {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, rgb(50,170,255) 0%, rgb(120,80,255) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 800;
    color: #fff;
    letter-spacing: 0.02em;
    flex-shrink: 0;
  }

  .auth-badge {
    display: inline-block;
    background: rgba(52,211,153,0.12);
    border: 1px solid rgba(52,211,153,0.25);
    color: rgb(52,211,153);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    padding: 0.2rem 0.65rem;
    border-radius: 999px;
  }

  .auth-name {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    margin: 0.25rem 0 0.1rem;
    line-height: 1.2;
  }

  .auth-role {
    font-size: 0.8rem;
    color: rgba(240,240,250,0.45);
    margin: 0;
  }

  .auth-meta {
    list-style: none;
    padding: 0;
    margin: 0.25rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;

    li {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.82rem;
      color: rgba(240,240,250,0.6);

      svg {
        width: 0.9rem;
        height: 0.9rem;
        flex-shrink: 0;
        color: rgba(50,170,255,0.7);
      }
    }
  }

  .auth-card__right {
    flex: 1;
    padding: 2.5rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;

    @media (max-width: 680px) {
      padding: 1.5rem;
    }
  }

  .auth-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #fff;
    line-height: 1.25;
    margin: 0;
  }

  .auth-sub {
    font-size: 0.875rem;
    color: rgba(240,240,250,0.5);
    line-height: 1.6;
    margin: 0;
  }

  .btn-google {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    background: #fff;
    color: #1f1f1f;
    border: none;
    border-radius: 999px;
    padding: 0.8rem 1.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    transition: box-shadow 0.15s, transform 0.15s;
    width: 100%;

    &:hover {
      box-shadow: 0 4px 20px rgba(0,0,0,0.4);
      transform: translateY(-1px);
    }

    &:active { transform: translateY(0); }
    &:disabled { opacity: 0.55; cursor: not-allowed; transform: none; }
  }

  .auth-disclaimer {
    font-size: 0.72rem;
    color: rgba(240,240,250,0.3);
    text-align: center;
    margin: 0;

    a { color: rgba(50,170,255,0.7); text-decoration: underline; }
    a:hover { color: #32aaff; }
  }

  /* ════════════════════════════════════════
     BOOKING WIDGET
  ════════════════════════════════════════ */
  .booking-widget {
    flex: 1;
    display: flex;
    align-items: flex-start;
    justify-content: center;
    padding: 5.5rem 1.5rem 4rem;
  }

  .book-wrap {
    display: flex;
    background: rgba(13,13,26,0.9);
    border: 1px solid rgba(255,255,255,0.09);
    border-radius: 1.5rem;
    overflow: hidden;
    max-width: 860px;
    width: 100%;
    min-height: 500px;
    box-shadow: 0 32px 80px rgba(0,0,0,0.5), 0 0 0 1px rgba(0,0,0,0.3);

    @media (max-width: 700px) {
      flex-direction: column;
      min-height: unset;
    }
  }

  /* ── Left info panel ── */
  .book-info {
    width: 240px;
    flex-shrink: 0;
    padding: 2rem 1.5rem;
    background: rgba(50,170,255,0.03);
    display: flex;
    flex-direction: column;
    gap: 1rem;

    @media (max-width: 700px) {
      width: 100%;
      padding: 1.5rem;
    }
  }

  .book-info__top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .book-avatar {
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 50%;
    background: linear-gradient(135deg, rgb(50,170,255) 0%, rgb(120,80,255) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    font-weight: 800;
    color: #fff;
    flex-shrink: 0;
  }

  .book-info__org {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(50,170,255,0.7);
    margin: 0;
  }

  .book-info__name {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
    margin: 0;
    line-height: 1.2;
  }

  .book-info__badge {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(52,211,153,0.1);
    border: 1px solid rgba(52,211,153,0.2);
    color: rgb(52,211,153);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
    width: fit-content;
  }

  .book-info__meta {
    list-style: none;
    padding: 0;
