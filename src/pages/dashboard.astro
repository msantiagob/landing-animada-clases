---
export const prerender = false;

import type { AstroGlobal } from 'astro';

// ── Auth guard ────────────────────────────────────────────────────────────────
const session = Astro.cookies.get('dashboard_session');
const isAuthed = session?.value === '1';
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Dashboard · Sonmyd</title>
    <meta name="robots" content="noindex, nofollow" />
    <style>
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

      :root {
        --bg: #07070f;
        --bg2: #0d0d1a;
        --bg3: #12121f;
        --border: rgba(255,255,255,0.07);
        --text: rgba(240,240,250,0.92);
        --muted: rgba(240,240,250,0.45);
        --brand: rgb(50,170,255);
        --green: rgb(52,211,153);
        --red: rgb(248,113,113);
        --yellow: rgb(251,191,36);
        --radius: 0.75rem;
        --radius-sm: 0.5rem;
      }

      body {
        background: var(--bg);
        color: var(--text);
        font-family: system-ui, -apple-system, sans-serif;
        font-size: 0.9rem;
        min-height: 100dvh;
      }

      /* ── Login screen ── */
      .login-wrap {
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1.5rem;
      }

      .login-card {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: 1.25rem;
        padding: 2.5rem 2rem;
        width: 100%;
        max-width: 22rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .login-logo {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--brand);
        letter-spacing: -0.02em;
      }

      .login-title {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--text);
      }

      .login-sub {
        font-size: 0.82rem;
        color: var(--muted);
        line-height: 1.5;
      }

      .btn-google {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.75rem;
        background: #fff;
        color: #3c4043;
        border: none;
        border-radius: 999px;
        padding: 0.7rem 1.25rem;
        font-size: 0.875rem;
        font-weight: 600;
        cursor: pointer;
        transition: box-shadow 0.15s;
        width: 100%;
      }

      .btn-google:hover { box-shadow: 0 2px 12px rgba(0,0,0,0.4); }
      .btn-google:disabled { opacity: 0.55; cursor: not-allowed; }

      .btn-google svg { flex-shrink: 0; }

      .login-error {
        color: var(--red);
        font-size: 0.8rem;
        min-height: 1.2em;
      }

      /* ── Dashboard layout ── */
      .dash {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2rem 1.5rem 4rem;
        display: flex;
        flex-direction: column;
        gap: 2rem;
      }

      .dash-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 1rem;
      }

      .dash-title {
        font-size: 1.5rem;
        font-weight: 700;
      }

      .dash-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        flex-wrap: wrap;
      }

      .btn-sm {
        padding: 0.4rem 0.875rem;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 600;
        border: 1px solid var(--border);
        background: var(--bg3);
        color: var(--muted);
        cursor: pointer;
        text-decoration: none;
        transition: color 0.15s, border-color 0.15s, background 0.15s;
        white-space: nowrap;
      }

      .btn-sm:hover { color: var(--text); border-color: rgba(255,255,255,0.18); }
      .btn-sm.danger { border-color: rgba(248,113,113,0.3); color: var(--red); }
      .btn-sm.danger:hover { background: rgba(248,113,113,0.08); }
      .btn-sm.primary { border-color: rgba(50,170,255,0.4); color: var(--brand); }
      .btn-sm.primary:hover { background: rgba(50,170,255,0.08); }

      /* ── Stats ── */
      .stats {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(11rem, 1fr));
        gap: 1rem;
      }

      .stat-card {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.25rem 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
      }

      .stat-label {
        font-size: 0.72rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
      }

      .stat-value {
        font-size: 2rem;
        font-weight: 800;
        color: var(--text);
        line-height: 1;
      }

      /* ── Filter bar ── */
      .filter-bar {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .filter-btn {
        padding: 0.35rem 0.875rem;
        border-radius: 999px;
        font-size: 0.78rem;
        font-weight: 600;
        border: 1px solid var(--border);
        background: transparent;
        color: var(--muted);
        cursor: pointer;
        transition: all 0.15s;
      }

      .filter-btn:hover { color: var(--text); border-color: rgba(255,255,255,0.18); }
      .filter-btn.active { background: rgba(50,170,255,0.12); border-color: rgba(50,170,255,0.4); color: var(--brand); }

      /* ── Table ── */
      .table-wrap {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        overflow: hidden;
      }

      .table-head {
        padding: 1rem 1.25rem;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .table-head-title {
        font-weight: 600;
        font-size: 0.9rem;
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      thead th {
        text-align: left;
        padding: 0.75rem 1.25rem;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--muted);
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
      }

      tbody tr {
        border-bottom: 1px solid var(--border);
        transition: background 0.1s;
      }

      tbody tr:last-child { border-bottom: none; }
      tbody tr:hover { background: rgba(255,255,255,0.02); }

      td {
        padding: 0.875rem 1.25rem;
        vertical-align: middle;
        font-size: 0.84rem;
      }

      .user-cell {
        display: flex;
        flex-direction: column;
        gap: 0.15rem;
      }

      .user-name { font-weight: 500; color: var(--text); }
      .user-email { font-size: 0.72rem; color: var(--muted); }

      .badge {
        display: inline-block;
        padding: 0.2rem 0.6rem;
        border-radius: 999px;
        font-size: 0.7rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        white-space: nowrap;
      }

      .badge-pending  { background: rgba(251,191,36,0.12);  color: var(--yellow); }
      .badge-confirmed{ background: rgba(52,211,153,0.12);  color: var(--green); }
      .badge-cancelled{ background: rgba(248,113,113,0.1);  color: var(--red); }
      .badge-completed{ background: rgba(50,170,255,0.1);   color: var(--brand); }

      .row-actions {
        display: flex;
        gap: 0.4rem;
        align-items: center;
      }

      .action-btn {
        padding: 0.25rem 0.6rem;
        border-radius: var(--radius-sm);
        font-size: 0.72rem;
        font-weight: 600;
        border: 1px solid transparent;
        cursor: pointer;
        background: transparent;
        transition: all 0.12s;
      }

      .action-confirm  { border-color: rgba(52,211,153,0.3);  color: var(--green); }
      .action-confirm:hover  { background: rgba(52,211,153,0.1); }
      .action-cancel   { border-color: rgba(248,113,113,0.3); color: var(--red); }
      .action-cancel:hover   { background: rgba(248,113,113,0.07); }
      .action-complete { border-color: rgba(50,170,255,0.3);  color: var(--brand); }
      .action-complete:hover { background: rgba(50,170,255,0.07); }

      .action-btn:disabled { opacity: 0.35; cursor: not-allowed; }

      .empty-state {
        text-align: center;
        padding: 3rem 1.25rem;
        color: var(--muted);
        font-size: 0.85rem;
      }

      /* ── Analytics link ── */
      .analytics-card {
        background: var(--bg2);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 1.25rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        flex-wrap: wrap;
      }

      .analytics-info { display: flex; flex-direction: column; gap: 0.25rem; }
      .analytics-title { font-weight: 600; font-size: 0.9rem; }
      .analytics-sub { font-size: 0.78rem; color: var(--muted); }

      /* ── Toast ── */
      #toast {
        position: fixed;
        bottom: 1.5rem;
        right: 1.5rem;
        background: var(--bg3);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 0.75rem 1.25rem;
        font-size: 0.83rem;
        color: var(--text);
        box-shadow: 0 8px 32px rgba(0,0,0,0.6);
        transform: translateY(1rem);
        opacity: 0;
        transition: opacity 0.25s, transform 0.25s;
        pointer-events: none;
        z-index: 100;
      }

      #toast.show { opacity: 1; transform: translateY(0); }

      /* ── Loading ── */
      .loading {
        text-align: center;
        padding: 2rem;
        color: var(--muted);
        font-size: 0.85rem;
      }

      @media (max-width: 640px) {
        .dash { padding: 1.25rem 1rem 3rem; }
        thead th:nth-child(3),
        td:nth-child(3) { display: none; }
      }
    </style>
  </head>
  <body>
    <!-- ── Login view (shown when not authenticated) ── -->
    <div class="login-wrap" id="login-view" style={isAuthed ? 'display:none' : ''}>
      <div class="login-card">
        <div class="login-logo">Sonmyd</div>
        <div>
          <p class="login-title">Dashboard de administración</p>
          <p class="login-sub" style="margin-top:0.5rem">Accede con tu cuenta de Google autorizada para gestionar las reservas y ver el analytics.</p>
        </div>
        <button class="btn-google" id="btn-login">
          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
            <path fill="#4285F4" d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.716v2.259h2.908c1.702-1.567 2.684-3.875 2.684-6.615Z"/>
            <path fill="#34A853" d="M9 18c2.43 0 4.467-.806 5.956-2.184l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332A8.997 8.997 0 0 0 9 18Z"/>
            <path fill="#FBBC05" d="M3.964 10.706A5.41 5.41 0 0 1 3.682 9c0-.593.102-1.17.282-1.706V4.962H.957A8.996 8.996 0 0 0 0 9c0 1.452.348 2.827.957 4.038l3.007-2.332Z"/>
            <path fill="#EA4335" d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0A8.997 8.997 0 0 0 .957 4.962L3.964 7.294C4.672 5.163 6.656 3.58 9 3.58Z"/>
          </svg>
          Continuar con Google
        </button>
        <p class="login-error" id="login-error"></p>
      </div>
    </div>

    <!-- ── Dashboard view (shown when authenticated) ── -->
    <div class="dash" id="dash-view" style={isAuthed ? '' : 'display:none'}>
      <div class="dash-header">
        <h1 class="dash-title">Dashboard · Sonmyd</h1>
        <div class="dash-actions">
          <a
            class="btn-sm primary"
            href="https://console.firebase.google.com/project/sonmyd-949cd/analytics"
            target="_blank"
            rel="noopener noreferrer"
          >
            Firebase Analytics
          </a>
          <button class="btn-sm danger" id="btn-logout">Cerrar sesión</button>
        </div>
      </div>

      <!-- Stats -->
      <div class="stats" id="stats">
        <div class="stat-card">
          <span class="stat-label">Total reservas</span>
          <span class="stat-value" id="stat-total">—</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Pendientes</span>
          <span class="stat-value" id="stat-pending" style="color:var(--yellow)">—</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Confirmadas</span>
          <span class="stat-value" id="stat-confirmed" style="color:var(--green)">—</span>
        </div>
        <div class="stat-card">
          <span class="stat-label">Canceladas</span>
          <span class="stat-value" id="stat-cancelled" style="color:var(--red)">—</span>
        </div>
      </div>

      <!-- Bookings table -->
      <div class="table-wrap">
        <div class="table-head">
          <span class="table-head-title">Reservas</span>
          <div class="filter-bar">
            <button class="filter-btn active" data-filter="all">Todas</button>
            <button class="filter-btn" data-filter="pending">Pendientes</button>
            <button class="filter-btn" data-filter="confirmed">Confirmadas</button>
            <button class="filter-btn" data-filter="cancelled">Canceladas</button>
          </div>
        </div>
        <div id="table-container">
          <div class="loading">Cargando reservas…</div>
        </div>
      </div>

      <!-- Analytics card -->
      <div class="analytics-card">
        <div class="analytics-info">
          <span class="analytics-title">Firebase Analytics & Performance</span>
          <span class="analytics-sub">Usuarios activos, eventos, conversiones y rendimiento del sitio en tiempo real.</span>
        </div>
        <a
          class="btn-sm primary"
          href="https://console.firebase.google.com/project/sonmyd-949cd/analytics"
          target="_blank"
          rel="noopener noreferrer"
        >
          Ver en Firebase →
        </a>
      </div>
    </div>

    <!-- Toast notification -->
    <div id="toast"></div>

    <script>
      // ── Types ──────────────────────────────────────────────────────────────
      type Status = 'pending' | 'confirmed' | 'cancelled' | 'completed';

      interface Booking {
        id: string;
        userName: string;
        userEmail: string;
        date: string;
        time: string;
        status: Status;
        lang: string;
        notes?: string;
        createdAt?: { seconds: number } | null;
      }

      // ── State ──────────────────────────────────────────────────────────────
      let allBookings: Booking[] = [];
      let activeFilter: string = 'all';

      // ── Toast helper ───────────────────────────────────────────────────────
      function showToast(msg: string, duration = 3000) {
        const toast = document.getElementById('toast')!;
        toast.textContent = msg;
        toast.classList.add('show');
        setTimeout(() => toast.classList.remove('show'), duration);
      }

      // ── Badge HTML ─────────────────────────────────────────────────────────
      function badgeHTML(status: Status): string {
        const labels: Record<Status, string> = {
          pending: 'Pendiente',
          confirmed: 'Confirmada',
          cancelled: 'Cancelada',
          completed: 'Completada',
        };
        return `<span class="badge badge-${status}">${labels[status] ?? status}</span>`;
      }

      // ── Format date ────────────────────────────────────────────────────────
      function fmtDate(iso: string): string {
        const [y, m, d] = iso.split('-').map(Number);
        return new Date(y, m - 1, d).toLocaleDateString('es-CO', {
          weekday: 'short', day: 'numeric', month: 'short', year: 'numeric',
        });
      }

      function fmtCreatedAt(ts: { seconds: number } | null | undefined): string {
        if (!ts) return '—';
        return new Date(ts.seconds * 1000).toLocaleDateString('es-CO', {
          day: 'numeric', month: 'short', year: 'numeric',
        });
      }

      // ── Render table ───────────────────────────────────────────────────────
      function renderTable() {
        const container = document.getElementById('table-container')!;
        const filtered = activeFilter === 'all'
          ? allBookings
          : allBookings.filter(b => b.status === activeFilter);

        if (filtered.length === 0) {
          container.innerHTML = `<div class="empty-state">No hay reservas${activeFilter !== 'all' ? ' con este filtro' : ''}.</div>`;
          return;
        }

        const rows = filtered.map(b => `
          <tr data-id="${b.id}">
            <td>
              <div class="user-cell">
                <span class="user-name">${escHtml(b.userName)}</span>
                <span class="user-email">${escHtml(b.userEmail)}</span>
              </div>
            </td>
            <td>${fmtDate(b.date)}<br><span style="color:var(--muted);font-size:0.78rem">${b.time}</span></td>
            <td>${fmtCreatedAt(b.createdAt)}</td>
            <td>${badgeHTML(b.status)}</td>
            <td>
              <div class="row-actions">
                ${b.status === 'pending' ? `
                  <button class="action-btn action-confirm" data-action="confirmed" data-id="${b.id}">Confirmar</button>
                  <button class="action-btn action-cancel"  data-action="cancelled" data-id="${b.id}">Cancelar</button>
                ` : ''}
                ${b.status === 'confirmed' ? `
                  <button class="action-btn action-complete" data-action="completed" data-id="${b.id}">Completar</button>
                  <button class="action-btn action-cancel"   data-action="cancelled" data-id="${b.id}">Cancelar</button>
                ` : ''}
                ${(b.status === 'cancelled' || b.status === 'completed') ? `<span style="color:var(--muted);font-size:0.75rem">—</span>` : ''}
              </div>
            </td>
          </tr>
        `).join('');

        container.innerHTML = `
          <div style="overflow-x:auto">
            <table>
              <thead>
                <tr>
                  <th>Usuario</th>
                  <th>Fecha / Hora</th>
                  <th>Agendado</th>
                  <th>Estado</th>
                  <th>Acciones</th>
                </tr>
              </thead>
              <tbody>${rows}</tbody>
            </table>
          </div>
        `;

        // Action buttons
        container.querySelectorAll<HTMLButtonElement>('[data-action]').forEach(btn => {
          btn.addEventListener('click', () => updateStatus(btn.dataset.id!, btn.dataset.action as Status, btn));
        });
      }

      function escHtml(s: string): string {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
      }

      // ── Update stats ───────────────────────────────────────────────────────
      function updateStats() {
        const total     = allBookings.length;
        const pending   = allBookings.filter(b => b.status === 'pending').length;
        const confirmed = allBookings.filter(b => b.status === 'confirmed').length;
        const cancelled = allBookings.filter(b => b.status === 'cancelled').length;
        document.getElementById('stat-total')!.textContent     = String(total);
        document.getElementById('stat-pending')!.textContent   = String(pending);
        document.getElementById('stat-confirmed')!.textContent = String(confirmed);
        document.getElementById('stat-cancelled')!.textContent = String(cancelled);
      }

      // ── Update booking status in Firestore ────────────────────────────────
      async function updateStatus(id: string, status: Status, btn: HTMLButtonElement) {
        btn.disabled = true;
        try {
          const { db } = await import('/src/lib/firebase.ts');
          const { doc, updateDoc } = await import('firebase/firestore');
          await updateDoc(doc(db, 'bookings', id), { status });
          const booking = allBookings.find(b => b.id === id);
          if (booking) booking.status = status;
          renderTable();
          updateStats();
          showToast(`Reserva ${status === 'confirmed' ? 'confirmada' : status === 'cancelled' ? 'cancelada' : 'completada'}.`);
        } catch (e) {
          console.error(e);
          showToast('Error al actualizar. Intenta de nuevo.');
          btn.disabled = false;
        }
      }

      // ── Filter buttons ─────────────────────────────────────────────────────
      document.querySelectorAll<HTMLButtonElement>('.filter-btn').forEach(btn => {
        btn.addEventListener('click', () => {
          activeFilter = btn.dataset.filter!;
          document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
          btn.classList.add('active');
          renderTable();
        });
      });

      // ── Load bookings from Firestore ───────────────────────────────────────
      async function loadBookings() {
        try {
          const { db } = await import('/src/lib/firebase.ts');
          const { collection, query, orderBy, onSnapshot } = await import('firebase/firestore');
          const q = query(collection(db, 'bookings'), orderBy('createdAt', 'desc'));
          onSnapshot(q, (snap) => {
            allBookings = snap.docs.map(d => ({ id: d.id, ...d.data() } as Booking));
            updateStats();
            renderTable();
          });
        } catch (e) {
          console.error(e);
          document.getElementById('table-container')!.innerHTML =
            '<div class="empty-state">Error al cargar las reservas.</div>';
        }
      }

      // ── Login ──────────────────────────────────────────────────────────────
      const btnLogin = document.getElementById('btn-login') as HTMLButtonElement | null;
      const loginError = document.getElementById('login-error')!;
      const loginView = document.getElementById('login-view')!;
      const dashView  = document.getElementById('dash-view')!;

      btnLogin?.addEventListener('click', async () => {
        btnLogin.disabled = true;
        loginError.textContent = '';
        try {
          const { auth, googleProvider } = await import('/src/lib/firebase.ts');
          const { signInWithPopup, getIdToken } = await import('firebase/auth');
          const result = await signInWithPopup(auth, googleProvider);
          const idToken = await getIdToken(result.user);
          const res = await fetch('/api/set-session', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ idToken }),
          });
          if (res.status === 403) {
            loginError.textContent = 'Esta cuenta no tiene acceso al dashboard.';
            btnLogin.disabled = false;
            return;
          }
          if (!res.ok) throw new Error('server error');
          // Reload to get SSR cookie recognised
          window.location.reload();
        } catch (e: any) {
          if (e?.code !== 'auth/popup-closed-by-user') {
            loginError.textContent = 'Error al iniciar sesión. Intenta de nuevo.';
          }
          btnLogin.disabled = false;
        }
      });

      // ── Logout ─────────────────────────────────────────────────────────────
      document.getElementById('btn-logout')?.addEventListener('click', async () => {
        try {
          const { auth } = await import('/src/lib/firebase.ts');
          const { signOut } = await import('firebase/auth');
          await signOut(auth);
        } catch { /* ignore */ }
        await fetch('/api/logout', { method: 'POST' });
        window.location.href = '/';
      });

      // ── Init: if already authed on SSR, load data ──────────────────────────
      if (dashView.style.display !== 'none') {
        loadBookings();
      }
    </script>
  </body>
</html>
