---
import Layout from "../../layouts/Layout.astro";
import HeroHome from "../../components/HeroHome.astro";
import TextMarquee from "../../components/TextMarquee.astro";
import Faqs from "../../components/Faqs.astro";
import StepsTimeline from "../../components/StepsTimeline.astro";
import Statements from "../../components/Statements.astro";
import Introducing from "../../components/Introducing.astro";
import GL from "../../components/GL.astro";
import GLPlaces from "../../components/GlPlaces.astro";
import ContactModal from "../../components/ContactModal.astro";

import fotoMiguel from "../../assets/img/foto_miguel.png";

const siteUrl = "https://sonmyd.co/";

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What can Sonmyd automate in my business?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sonmyd automates Google Calendar (appointments, reminders and scheduling), WhatsApp Business (automatic replies, notifications and chatbots), website creation and maintenance, and any repetitive workflow in your business using artificial intelligence.",
      },
    },
    {
      "@type": "Question",
      "name": "How does the Google Calendar integration work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We connect your Google Calendar to automatically schedule appointments, send reminders to your clients, block available time slots and sync with your existing tools. No manual intervention needed.",
      },
    },
    {
      "@type": "Question",
      "name": "What kind of WhatsApp automations does Sonmyd build?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We implement intelligent chatbots, 24/7 automatic replies, appointment and order notifications, lead qualification and human escalation. All integrated with WhatsApp Business API.",
      },
    },
    {
      "@type": "Question",
      "name": "Do I need technical knowledge to use Sonmyd?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Sonmyd handles all the technical side. You define what you want to automate and we build and deploy the solution. You just need to know your business processes.",
      },
    },
    {
      "@type": "Question",
      "name": "How long does it take to have my automation ready?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on scope. A basic WhatsApp or Calendar automation can be ready in a few days. A full website with integrated automations may take one to three weeks.",
      },
    },
    {
      "@type": "Question",
      "name": "Is there a free session to evaluate my project?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. The first diagnosis session is completely free. We analyze your processes, identify what to automate and present a concrete plan with no commitment.",
      },
    },
  ],
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": `${siteUrl}en`,
    },
  ],
};
---

<Layout title="Sonmyd — AI Automations: WhatsApp, Google Calendar and Websites">
  <Fragment slot="head">
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schemaFAQ)}</script>`} />
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schemaBreadcrumb)}</script>`} />
  </Fragment>
  <!-- ══════════════════════════════════════════════════════════════════════
       APP IDENTITY — always visible section, no animations, no JS required.
       Google OAuth verification requires the app name and purpose to be
       visible as plain text, without relying on JavaScript.
       ══════════════════════════════════════════════════════════════════════ -->
  <section class="app-id" aria-labelledby="app-id-title">
    <div class="u-container app-id__inner">
      <div class="app-id__brand">
        <span class="app-id__name" id="app-id-title">Sonmyd</span>
        <span class="app-id__sep" aria-hidden="true">·</span>
        <span class="app-id__tagline">AI automation platform</span>
      </div>
      <p class="app-id__purpose">
        <strong>Sonmyd</strong> connects to <strong>Google Calendar</strong> via OAuth to automatically create and manage appointments. It also integrates <strong>WhatsApp Business</strong> to respond to clients 24/7 and builds professional websites for your business.
      </p>
      <nav class="app-id__links" aria-label="Legal">
        <a href="/en/privacy">Privacy Policy</a>
        <span aria-hidden="true">·</span>
        <a href="/en/terms">Terms of Use</a>
      </nav>
    </div>
  </section>

  <div id="inicio">
    <HeroHome
      title="Sonmyd: automate your business with AI."
      subtitle="Connect Google Calendar, manage WhatsApp, build your website and eliminate repetitive work. Technology that works for you, 24/7."
      cta={{
        title: "Start for free",
        url: "#contacto",
      }}
      ctaModalPlan="Free Session"
      whatsappUrl="https://wa.me/573106041144?text=Hi%2C+I%27m+interested+in+automating+my+business+with+Sonmyd."
    />
    <div class="photo-inner">
      <img src={fotoMiguel.src} alt="Miguel Zuluaga — Sonmyd" />
    </div>
  </div>

  <div id="clases">
    <Introducing
      title="Sonmyd is your AI automation team"
      text="We build smart integrations between your tools: auto-schedule appointments with Google Calendar, respond to clients on WhatsApp around the clock, launch your professional website in days. All with AI, no code, no complexity."
      cta={{
        title: "See all services",
        url: "/en/services",
      }}
    />
  </div>

  <TextMarquee
    class="marquee"
    texts={[
      "Google Calendar",
      "WhatsApp Business",
      "Websites",
      "AI Automation",
      "Chatbots",
      "Integrations",
    ]}
  />

  <div id="metodologia">
    <StepsTimeline
      title="How Sonmyd works"
      items={[
        {
          title: "Process diagnosis",
          text: "We analyze together which tasks consume your time: scheduling appointments, replying to messages, updating your site. We identify the highest-impact points.",
        },
        {
          title: "Automation design",
          text: "We build custom flows: Calendar connected to your business, WhatsApp that replies on its own, forms that trigger automatic actions.",
        },
        {
          title: "Implementation & testing",
          text: "We deploy everything, run real tests and fine-tune until it works perfectly. You approve before going live.",
        },
        {
          title: "Monitoring & support",
          text: "Once live, we monitor that everything runs smoothly. If your business changes, we update the automation to keep it aligned.",
        },
      ]}
    />
  </div>

  <Statements
    items={[
      {
        title: "Google Calendar that schedules itself",
        text: "Your clients book appointments, receive automatic reminders and you don't lift a finger. No missed calls, no double bookings.",
      },
      {
        title: "WhatsApp working around the clock",
        text: "An intelligent assistant responds, qualifies and serves your clients on WhatsApp while you sleep. Escalates to humans when needed.",
      },
      {
        title: "Your website, ready in days",
        text: "We create your professional digital presence: fast, optimized for Google and connected to your automations from day one.",
      },
    ]}
  />

  <TextMarquee
    class="marquee"
    texts={[
      "Automatic scheduling",
      "AI-powered chatbots",
      "Smart forms",
      "Automatic notifications",
      "Fast websites",
      "API integrations",
    ]}
  />

  <div id="contacto">
    <Faqs
      title="Frequently Asked Questions"
      mobileTitle="FAQs"
      subtitle="Everything you need to know about Sonmyd and its automations."
      items={[
        {
          question: "What can Sonmyd automate in my business?",
          answer:
            "Sonmyd automates Google Calendar (appointments, reminders and scheduling), WhatsApp Business (automatic replies, notifications and chatbots), website creation and maintenance, and any repetitive workflow in your business using artificial intelligence.",
        },
        {
          question: "How does the Google Calendar integration work?",
          answer:
            "We connect your Google Calendar to automatically schedule appointments, send reminders to your clients, block available time slots and sync with your existing tools. No manual intervention needed.",
        },
        {
          question: "What kind of WhatsApp automations does Sonmyd build?",
          answer:
            "We implement intelligent chatbots, 24/7 automatic replies, appointment and order notifications, lead qualification and human escalation. All integrated with WhatsApp Business API.",
        },
        {
          question: "Do I need technical knowledge to use Sonmyd?",
          answer:
            "No. Sonmyd handles all the technical side. You define what you want to automate and we build and deploy the solution. You just need to know your business processes.",
        },
        {
          question: "How long does it take to have my automation ready?",
          answer:
            "It depends on scope. A basic WhatsApp or Calendar automation can be ready in a few days. A full website with integrated automations may take one to three weeks.",
        },
        {
          question: "Is there a free session to evaluate my project?",
          answer:
            "Yes. The first diagnosis session is completely free. We analyze your processes, identify what to automate and present a concrete plan with no commitment.",
        },
      ]}
    />
  </div>

  <div class="app-info u-container">
    <p class="app-info__brand">Sonmyd</p>
    <p class="app-info__desc">
      AI automation platform: integrations with Google Calendar, WhatsApp Business, website creation and business process automation. This site uses Google Analytics (via Google Tag Manager) to measure web traffic anonymously.
    </p>
    <nav class="app-info__links" aria-label="Legal">
      <a href="/en/privacy">Privacy Policy</a>
      <span aria-hidden="true">·</span>
      <a href="/en/terms">Terms of Use</a>
    </nav>
  </div>

  <GL />
  <GLPlaces />
  <ContactModal />
</Layout>

<script>
  const EU = new Set([
    "ES","FR","DE","IT","PT","NL","BE","AT","CH","SE","NO","DK","FI",
    "IE","GR","PL","CZ","HU","RO","BG","HR","SK","SI","EE","LV","LT",
    "LU","MT","CY","IS","LI","AL","RS","BA","ME","MK","MD",
  ]);

  type PriceEntry = {
    amount: string;
    duration: string;
    savings?: string;
  };
  type CountryPricing = {
    individual: PriceEntry;
    paquete: PriceEntry;
  };

  const PRICING: Record<string, CountryPricing> = {
    DEFAULT: {
      individual: { amount: "$25",      duration: "session" },
      paquete:    { amount: "$220",     duration: "10 hrs",   savings: "Save $30" },
    },
    CO: {
      individual: { amount: "$80.000",  duration: "session" },
      paquete:    { amount: "$750.000", duration: "10 hours" },
    },
    EU: {
      individual: { amount: "€25",      duration: "session" },
      paquete:    { amount: "€220",     duration: "10 hours", savings: "Save €30" },
    },
    MX: {
      individual: { amount: "$450",     duration: "session" },
      paquete:    { amount: "$4.000",   duration: "10 hours", savings: "Save $500" },
    },
  };

  function applyPricing(pricing: CountryPricing) {
    const plans = [pricing.individual, pricing.paquete];
    plans.forEach((plan, i) => {
      const amountEl = document.querySelector<HTMLElement>(`[data-plan-amount="${i}"]`);
      const durationEl = document.querySelector<HTMLElement>(`[data-plan-duration="${i}"]`);
      const savingsEl = document.querySelector<HTMLElement>(`[data-plan-savings="${i}"]`);
      if (amountEl) amountEl.textContent = plan.amount;
      if (durationEl) durationEl.textContent = `/${plan.duration}`;
      if (savingsEl) {
        savingsEl.textContent = plan.savings ?? "";
        savingsEl.classList.toggle("visible", !!plan.savings);
      }
    });
  }

  async function getCountryCode(): Promise<string> {
    try {
      const res = await fetch("https://cloudflare.com/cdn-cgi/trace");
      const text = await res.text();
      const match = text.match(/^loc=([A-Z]{2})$/m);
      if (match?.[1]) return match[1];
    } catch { /* fall through */ }
    try {
      const res = await fetch("https://ipapi.co/json/");
      const data = await res.json();
      if (data.country_code) return data.country_code;
    } catch { /* fall through */ }
    return "DEFAULT";
  }

  async function detectAndApply() {
    const countryCode = await getCountryCode();
    let pricing: CountryPricing;
    if (PRICING[countryCode]) {
      pricing = PRICING[countryCode];
    } else if (EU.has(countryCode)) {
      pricing = PRICING.EU;
    } else {
      pricing = PRICING.DEFAULT;
    }
    applyPricing(pricing);
  }

  detectAndApply();
</script>

<style>
  /* ── App Identity ── always visible, no animations ── */
  .app-id {
    position: relative;
    z-index: 1;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    padding: 5.5rem 0 1rem;
    opacity: 1 !important;
    visibility: visible !important;
  }
  .app-id__inner {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    opacity: 1 !important;
  }
  .app-id__brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    opacity: 1 !important;
  }
  .app-id__name {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #fff;
    opacity: 1 !important;
  }
  .app-id__sep {
    color: rgba(255, 255, 255, 0.3);
  }
  .app-id__tagline {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    opacity: 1 !important;
  }
  .app-id__purpose {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.5;
    max-width: 56rem;
    margin: 0;
    opacity: 1 !important;

    strong {
      color: rgba(255, 255, 255, 0.8);
      font-weight: 600;
    }
  }
  .app-id__links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.3);
    opacity: 1 !important;
  }
  .app-id__links a {
    color: rgba(50, 170, 255, 0.7);
    text-decoration: underline;
    text-underline-offset: 2px;
    opacity: 1 !important;
  }
  .app-id__links a:hover {
    color: #32aaff;
  }

  .app-info {
    padding: 3rem 0 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .app-info__brand {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }
  .app-info__desc {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.3);
    max-width: 46rem;
    line-height: 1.6;
  }
  .app-info__links {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.3);
  }
  .app-info__links a {
    color: rgba(255,255,255,0.45);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .app-info__links a:hover {
    color: rgba(255,255,255,0.75);
  }

  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }

  .photo-inner {
    margin: auto;
    position: relative;
    z-index: 9;
    width: 22rem;
    height: 26rem;
    border-radius: 2rem;
    overflow: hidden;
    border: 1.5px solid rgba(50, 170, 255, 0.5);
    box-shadow:
      0 0 60px rgba(50, 170, 255, 0.25),
      0 0 120px rgba(235, 14, 56, 0.08),
      inset 0 0 30px rgba(0, 0, 0, 0.5);

    @media (--mq-tablet) {
      width: 18rem;
      height: 22rem;
    }

    @media (--mq-phone) {
      width: 14rem;
      height: 17rem;
    }

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
    }
  }
</style>
