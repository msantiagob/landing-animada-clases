---
import LayoutPage from "../../layouts/LayoutPage.astro";
import { getBookableDates, WEEKLY_SLOTS } from "../../lib/schedule";

const dates = getBookableDates(28);
const slotsJson = JSON.stringify(WEEKLY_SLOTS);
const datesJson = JSON.stringify(dates);
---

<LayoutPage
  title="Schedule a Meeting | Sonmyd — Miguel Zuluaga"
  description="Book a meeting with Miguel Zuluaga from Sonmyd. Free diagnosis session to evaluate your AI automation project."
>
  <div class="book-page">

    <div id="auth-gate" class="auth-gate">
      <div class="u-container auth-gate__inner">
        <span class="auth-gate__icon">📅</span>
        <h1 class="u-heading auth-gate__title">Schedule a meeting</h1>
        <p class="u-text auth-gate__sub">
          Sign in with your Google account to book a session. The first diagnosis session is free.
        </p>
        <button id="btn-google-login" class="btn-google">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/>
            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
          </svg>
          Continue with Google
        </button>
      </div>
    </div>

    <div id="booking-widget" class="booking-widget" style="display:none">
      <div class="u-container">
        <div class="user-bar">
          <img id="user-photo" src="" alt="" class="user-bar__photo" />
          <span id="user-name" class="user-bar__name"></span>
          <button id="btn-logout" class="user-bar__logout">Sign out</button>
        </div>

        <div class="book-grid">
          <aside class="book-info">
            <div class="book-info__avatar">
              <img src="/foto_miguel.png" alt="Miguel Zuluaga" onerror="this.style.display='none'" />
            </div>
            <h1 class="u-heading book-info__name">Miguel Zuluaga</h1>
            <p class="u-text book-info__role">Founder of Sonmyd · AI Expert</p>
            <ul class="book-info__details">
              <li><span>⏱</span> 30 minutes</li>
              <li><span>🎥</span> Google Meet / Zoom</li>
              <li><span>🌎</span> Colombia time (UTC-5)</li>
            </ul>
            <p class="book-info__desc">
              Free diagnosis session. We analyze your project, identify what to automate and design a concrete plan.
            </p>
          </aside>

          <div class="book-picker">
            <div id="step-date" class="step">
              <h2 class="step__title">Select a date</h2>
              <div class="cal">
                <div class="cal__nav">
                  <button class="cal__nav-btn" id="cal-prev" aria-label="Previous month">
                    <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M10 3L5 8l5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <span class="cal__month-label" id="cal-month-label"></span>
                  <button class="cal__nav-btn" id="cal-next" aria-label="Next month">
                    <svg viewBox="0 0 16 16" fill="none" aria-hidden="true"><path d="M6 3l5 5-5 5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                </div>
                <div class="cal__weekdays" aria-hidden="true">
                  <span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span>
                </div>
                <div class="cal__days" id="cal-days"></div>
              </div>
            </div>

            <div id="step-time" class="step" style="display:none">
              <h2 class="step__title">Choose a time
                <button id="btn-back-date" class="step__back">← Change date</button>
              </h2>
              <div id="slots-grid" class="slots-grid"></div>
            </div>

            <div id="step-confirm" class="step" style="display:none">
              <h2 class="step__title">Confirm your booking</h2>
              <div class="confirm-card">
                <div class="confirm-card__row"><span>📅</span><span id="confirm-date-text"></span></div>
                <div class="confirm-card__row"><span>🕐</span><span id="confirm-time-text"></span></div>
                <div class="confirm-card__row"><span>⏱</span><span>30 minutes · Colombia time</span></div>
              </div>
              <label class="notes-label">
                What do you want to discuss? <span class="notes-optional">(optional)</span>
                <textarea id="notes-input" class="notes-input" rows="3" placeholder="e.g. I want to automate my clinic's scheduling with Google Calendar..."></textarea>
              </label>
              <button id="btn-back-time" class="step__back" style="margin-bottom:1rem">← Change time</button>
              <button id="btn-confirm" class="btn-confirm">Confirm booking</button>
            </div>

            <div id="step-success" class="step step--success" style="display:none">
              <div class="success-icon">✅</div>
              <h2 class="u-heading">Booking confirmed!</h2>
              <p class="u-text" id="success-text"></p>
              <p class="u-text" style="color:rgba(255,255,255,0.5);font-size:0.85rem;margin-top:0.5rem">
                You'll receive confirmation at your Google email. Miguel will be in touch soon.
              </p>
              <a href="/en" class="btn-confirm" style="text-decoration:none;display:inline-block;margin-top:1.5rem">Back to home</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</LayoutPage>

<!-- Expose server data as globals (inline — no module) -->
<script define:vars={{ slotsJson, datesJson }} is:inline>
  window.__BOOK_SLOTS__ = JSON.parse(slotsJson);
  window.__BOOK_DATES__ = JSON.parse(datesJson);
</script>

<!-- Main logic — Vite module, supports static imports -->
<script>
  import { auth, db, googleProvider } from '../../lib/firebase.ts';
  import { onAuthStateChanged, signInWithPopup, signOut } from 'firebase/auth';
  import { collection, addDoc, serverTimestamp, query, where, getDocs } from 'firebase/firestore';

  const WEEKLY_SLOTS: Record<number, string[]> = (window as any).__BOOK_SLOTS__;
  const DATES: string[] = (window as any).__BOOK_DATES__;
  let selectedDate = '', selectedTime = '';

  onAuthStateChanged(auth, (user) => {
    if (user) showWidget(user);
    else {
      const gate = document.getElementById('auth-gate');
      const widget = document.getElementById('booking-widget');
      if (gate) gate.style.display = '';
      if (widget) widget.style.display = 'none';
    }
  });

  document.getElementById('btn-google-login')?.addEventListener('click', async () => {
    try { await signInWithPopup(auth, googleProvider); } catch(e: any) {
      if (e?.code !== 'auth/popup-closed-by-user') console.error(e);
    }
  });
  document.getElementById('btn-logout')?.addEventListener('click', () => signOut(auth));
  document.getElementById('btn-back-date')?.addEventListener('click', () => showStep('date'));
  document.getElementById('btn-back-time')?.addEventListener('click', () => showStep('time'));
  document.getElementById('btn-confirm')?.addEventListener('click', confirmBooking);

  function showWidget(user: any) {
    document.getElementById('auth-gate')!.style.display = 'none';
    document.getElementById('booking-widget')!.style.display = '';
    document.getElementById('user-name')!.textContent = user.displayName ?? user.email;
    const photo = document.getElementById('user-photo') as HTMLImageElement;
    if (user.photoURL) { photo.src = user.photoURL; photo.alt = user.displayName; }
    else { photo.style.display = 'none'; }
    initCalendar();
  }

  // ── Calendar ───────────────────────────────────────────────────────────────
  const BOOKABLE = new Set(DATES);
  const MONTH_NAMES = ['January','February','March','April','May','June','July','August','September','October','November','December'];

  const [fy, fm] = DATES[0].split('-').map(Number);
  let calYear = fy;
  let calMonth = fm - 1;

  const [ly, lm] = DATES[DATES.length - 1].split('-').map(Number);
  const minMonth = { year: fy, month: fm - 1 };
  const maxMonth = { year: ly, month: lm - 1 };

  function initCalendar() {
    renderCalendar();
    document.getElementById('cal-prev')!.addEventListener('click', () => {
      if (calYear > minMonth.year || calMonth > minMonth.month) {
        calMonth--;
        if (calMonth < 0) { calMonth = 11; calYear--; }
        renderCalendar();
      }
    });
    document.getElementById('cal-next')!.addEventListener('click', () => {
      if (calYear < maxMonth.year || calMonth < maxMonth.month) {
        calMonth++;
        if (calMonth > 11) { calMonth = 0; calYear++; }
        renderCalendar();
      }
    });
  }

  function renderCalendar() {
    const label   = document.getElementById('cal-month-label')!;
    const grid    = document.getElementById('cal-days')!;
    const prevBtn = document.getElementById('cal-prev') as HTMLButtonElement;
    const nextBtn = document.getElementById('cal-next') as HTMLButtonElement;

    label.textContent = `${MONTH_NAMES[calMonth]} ${calYear}`;
    prevBtn.disabled = calYear === minMonth.year && calMonth === minMonth.month;
    nextBtn.disabled = calYear === maxMonth.year && calMonth === maxMonth.month;

    grid.innerHTML = '';

    const firstDow = new Date(calYear, calMonth, 1).getDay();
    const offset = firstDow === 0 ? 6 : firstDow - 1;
    const daysInMonth = new Date(calYear, calMonth + 1, 0).getDate();
    const todayIso = new Date().toISOString().slice(0, 10);

    for (let i = 0; i < offset; i++) {
      const empty = document.createElement('div');
      empty.className = 'cal-day cal-day--empty';
      grid.appendChild(empty);
    }

    for (let d = 1; d <= daysInMonth; d++) {
      const iso = `${calYear}-${String(calMonth + 1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
      const isAvail    = BOOKABLE.has(iso);
      const isSelected = iso === selectedDate;
      const isToday    = iso === todayIso;

      const cell = document.createElement('button');
      cell.type = 'button';
      cell.textContent = String(d);
      cell.className = [
        'cal-day',
        isAvail    ? 'cal-day--avail'    : 'cal-day--off',
        isSelected ? 'cal-day--selected' : '',
        isToday    ? 'cal-day--today'    : '',
      ].filter(Boolean).join(' ');
      cell.disabled = !isAvail;
      cell.setAttribute('aria-label', iso);

      if (isAvail) cell.addEventListener('click', () => selectDate(iso));
      grid.appendChild(cell);
    }
  }

  function selectDate(iso: string) {
    selectedDate = iso;
    renderCalendar();
    showStep('time');
    loadSlots(iso);
  }

  async function loadSlots(iso: string) {
    const grid = document.getElementById('slots-grid')!;
    grid.innerHTML = '<p style="color:rgba(255,255,255,0.4);font-size:0.85rem">Loading availability...</p>';
    const q = query(collection(db, 'bookings'), where('date', '==', iso), where('status', '!=', 'cancelled'));
    const snap = await getDocs(q);
    const booked = new Set(snap.docs.map(d => d.data().time));
    const [y, m, day] = iso.split('-').map(Number);
    const dow = new Date(y, m - 1, day).getDay();
    const slots = WEEKLY_SLOTS[dow] ?? [];
    if (slots.length === 0) {
      grid.innerHTML = '<p class="slots-empty">No slots available for this day.</p>';
      return;
    }

    grid.innerHTML = '';
    slots.forEach(time => {
      const taken = booked.has(time);
      const [hStr, minStr] = time.split(':');
      const h = Number(hStr);
      const ampm = h < 12 ? 'AM' : 'PM';
      const h12 = h === 0 ? 12 : h > 12 ? h - 12 : h;

      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'slot-btn' + (taken ? ' is-taken' : '');
      btn.disabled = taken;
      btn.innerHTML = `
        <span class="slot-btn__time">${h12}:${minStr}</span>
        <span class="slot-btn__ampm">${ampm} · COT</span>
        ${taken ? '<span class="slot-btn__taken-label">Taken</span>' : ''}
      `;
      btn.addEventListener('click', () => selectTime(time, btn));
      grid.appendChild(btn);
    });
  }

  function selectTime(time, btn) {
    selectedTime = time;
    document.querySelectorAll('.slot-btn').forEach(b => b.classList.remove('is-selected'));
    btn.classList.add('is-selected');
    fillConfirm();
    showStep('confirm');
  }

  function fillConfirm() {
    const [y, m, d] = selectedDate.split('-').map(Number);
    const date = new Date(y, m - 1, d);
    document.getElementById('confirm-date-text').textContent = date.toLocaleDateString('en-US', { weekday:'long', day:'numeric', month:'long', year:'numeric' });
    document.getElementById('confirm-time-text').textContent = selectedTime + ' (Colombia time)';
  }

  async function confirmBooking() {
    const user = auth.currentUser;
    if (!user) return;
    const btn = document.getElementById('btn-confirm');
    btn.disabled = true; btn.textContent = 'Saving...';
    try {
      const slotKey = `${selectedDate}_${selectedTime}`;
      const q = query(collection(db, 'bookings'), where('slotKey', '==', slotKey), where('status', '!=', 'cancelled'));
      const existing = await getDocs(q);
      if (!existing.empty) {
        alert('This slot was just booked. Please choose another.');
        showStep('time'); loadSlots(selectedDate); return;
      }
      const notes = document.getElementById('notes-input').value.trim();
      await addDoc(collection(db, 'bookings'), {
        userId: user.uid, userEmail: user.email, userName: user.displayName ?? user.email,
        userPhoto: user.photoURL ?? '', date: selectedDate, time: selectedTime,
        slotKey, status: 'pending', lang: 'en', notes, createdAt: serverTimestamp(),
      });
      const [y, m, d] = selectedDate.split('-').map(Number);
      const dateObj = new Date(y, m - 1, d);
      document.getElementById('success-text').textContent =
        `Your meeting on ${dateObj.toLocaleDateString('en-US', { weekday:'long', month:'long', day:'numeric' })} at ${selectedTime} COT is confirmed.`;
      showStep('success');
    } catch(e) {
      console.error(e);
      alert('An error occurred. Please try again.');
      btn.disabled = false; btn.textContent = 'Confirm booking';
    }
  }

  function showStep(name) {
    ['date','time','confirm','success'].forEach(s => {
      document.getElementById(`step-${s}`).style.display = s === name ? '' : 'none';
    });
  }
</script>

<style>@import "../../styles/_service-page.css";</style>

<style>
  /* shared with /agendar — same design tokens */
  .cal { user-select: none; }
  .cal__nav { display:flex; align-items:center; justify-content:space-between; margin-bottom:1.25rem; gap:0.5rem; }
  .cal__month-label { font-size:0.95rem; font-weight:700; color:#fff; flex:1; text-align:center; }
  .cal__nav-btn { width:2.25rem; height:2.25rem; display:flex; align-items:center; justify-content:center; background:transparent; border:1px solid rgba(255,255,255,0.12); border-radius:50%; color:rgba(240,240,250,0.55); cursor:pointer; transition:background 0.15s,border-color 0.15s,color 0.15s; flex-shrink:0; svg{width:0.8rem;height:0.8rem;} &:hover:not(:disabled){background:rgba(50,170,255,0.12);border-color:rgba(50,170,255,0.4);color:rgb(50,170,255);} &:disabled{opacity:0.2;cursor:not-allowed;} }
  .cal__weekdays { display:grid; grid-template-columns:repeat(7,1fr); margin-bottom:0.5rem; border-bottom:1px solid rgba(255,255,255,0.06); padding-bottom:0.5rem; span{text-align:center;font-size:0.62rem;font-weight:700;text-transform:uppercase;letter-spacing:0.08em;color:rgba(240,240,250,0.25);padding:0.2rem 0;} }
  .cal__days { display:grid; grid-template-columns:repeat(7,1fr); gap:0.125rem; }
  .cal-day { all:unset; box-sizing:border-box; display:flex; align-items:center; justify-content:center; aspect-ratio:1; border-radius:50%; font-size:0.8rem; font-weight:500; cursor:default; position:relative; transition:background 0.13s,color 0.13s,transform 0.12s,box-shadow 0.13s; background:transparent; color:transparent; }
  .cal-day--empty { pointer-events:none; }
  .cal-day--off { color:rgba(240,240,250,0.15); cursor:not-allowed; }
  .cal-day--avail { color:rgba(240,240,250,0.85); font-weight:600; cursor:pointer; &::before{content:'';position:absolute;top:18%;right:18%;width:5px;height:5px;border-radius:50%;background:rgba(50,170,255,0.5);transition:opacity 0.12s;} &:hover{background:rgba(50,170,255,0.14);color:rgb(50,170,255);transform:scale(1.12);box-shadow:0 2px 12px rgba(50,170,255,0.2);&::before{opacity:0;}} }
  .cal-day--today:not(.cal-day--selected) { border:1.5px solid rgba(50,170,255,0.4); color:rgb(50,170,255); font-weight:700; &::before{opacity:0;} }
  .cal-day--selected { background:rgb(50,170,255)!important; color:#fff!important; font-weight:700; box-shadow:0 4px 16px rgba(50,170,255,0.45); transform:scale(1.12); &::before{opacity:0!important;} }

  .slots-grid { display:grid; grid-template-columns:repeat(auto-fill,minmax(8.5rem,1fr)); gap:0.625rem; }
  .slots-empty { color:rgba(240,240,250,0.35); font-size:0.82rem; padding:1rem 0; margin:0; }
  .slot-btn { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.1); border-radius:0.75rem; color:rgba(240,240,250,0.85); cursor:pointer; padding:0.75rem 0.875rem; transition:background 0.15s,border-color 0.15s,transform 0.12s,box-shadow 0.15s; text-align:left; display:flex; flex-direction:column; gap:0.15rem; position:relative; overflow:hidden; &::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:rgba(50,170,255,0);border-radius:3px 0 0 3px;transition:background 0.15s;} &:hover:not(:disabled){background:rgba(50,170,255,0.07);border-color:rgba(50,170,255,0.3);transform:translateY(-2px);box-shadow:0 4px 16px rgba(50,170,255,0.12);&::before{background:rgb(50,170,255);}} &.is-selected{background:rgba(50,170,255,0.12);border-color:rgba(50,170,255,0.5);box-shadow:0 4px 20px rgba(50,170,255,0.18);&::before{background:rgb(50,170,255);}} &.is-taken{opacity:0.3;cursor:not-allowed;&::before{background:rgba(248,113,113,0.4);}} }
  .slot-btn__time { font-size:1rem; font-weight:700; color:rgba(240,240,250,0.9); line-height:1; }
  .slot-btn__ampm { font-size:0.67rem; font-weight:500; color:rgba(240,240,250,0.35); letter-spacing:0.04em; }
  .slot-btn__taken-label { font-size:0.65rem; color:rgba(248,113,113,0.6); margin-top:0.1rem; }
  .slot-btn:hover:not(:disabled) .slot-btn__time { color:rgb(50,170,255); }
  .slot-btn:hover:not(:disabled) .slot-btn__ampm { color:rgba(50,170,255,0.7); }
  .slot-btn.is-selected .slot-btn__time { color:rgb(50,170,255); }
  .slot-btn.is-selected .slot-btn__ampm { color:rgba(50,170,255,0.65); }

  .step__title { font-size:1rem; font-weight:600; color:rgba(255,255,255,0.9); margin:0 0 1.25rem; }
  .step__header { display:flex; align-items:center; gap:0.75rem; margin-bottom:1.25rem; .step__title{margin:0;} }
  .step__back { background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:0.5rem; color:rgba(240,240,250,0.6); font-size:0.78rem; padding:0.3rem 0.65rem; cursor:pointer; transition:background 0.15s,color 0.15s; &:hover{background:rgba(255,255,255,0.09);color:rgba(240,240,250,0.9);} }

  .confirm-card { background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.08); border-radius:0.875rem; padding:1.125rem 1.25rem; margin-bottom:1.25rem; display:flex; flex-direction:column; }
  .confirm-row { display:flex; align-items:center; gap:0.875rem; padding:0.65rem 0; border-bottom:1px solid rgba(255,255,255,0.05); font-size:0.875rem; &:last-child{border-bottom:none;} > div{display:flex;flex-direction:column;gap:0.1rem;} }
  .confirm-icon { font-size:1rem; width:1.5rem; text-align:center; }
  .confirm-label { font-size:0.68rem; font-weight:600; text-transform:uppercase; letter-spacing:0.07em; color:rgba(240,240,250,0.35); display:block; }
  .confirm-value { font-size:0.875rem; font-weight:500; color:rgba(240,240,250,0.85); display:block; }

  .notes-label { display:flex; flex-direction:column; gap:0.3rem; font-size:0.82rem; font-weight:500; color:rgba(240,240,250,0.6); margin-bottom:1rem; }
  .notes-optional { font-size:0.7rem; color:rgba(240,240,250,0.3); font-weight:400; margin-left:0.3rem; }
  .notes-input { background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.09); border-radius:0.625rem; color:rgba(240,240,250,0.85); font-family:inherit; font-size:0.85rem; padding:0.75rem; resize:vertical; width:100%; margin-top:0.25rem; &::placeholder{color:rgba(240,240,250,0.2);} &:focus{outline:none;border-color:rgba(50,170,255,0.4);} }

  .btn-confirm { width:100%; background:rgb(50,170,255); border:none; border-radius:0.75rem; color:#fff; cursor:pointer; font-size:0.9rem; font-weight:700; padding:0.875rem; transition:opacity 0.15s,transform 0.15s; text-align:center; text-decoration:none; display:block; &:hover{opacity:0.88;transform:translateY(-1px);} &:disabled{opacity:0.4;cursor:not-allowed;transform:none;} }

  .step--success { display:flex; flex-direction:column; align-items:center; text-align:center; gap:0.75rem; padding:2rem 1rem; }
  .success-check svg { width:3.5rem; height:3.5rem; }
  .success-title { font-size:1.25rem; font-weight:700; color:#fff; margin:0; }
  .success-text { font-size:0.9rem; color:rgba(240,240,250,0.65); margin:0; line-height:1.5; }
  .success-sub { font-size:0.78rem; color:rgba(240,240,250,0.35); margin:0; line-height:1.6; }
</style>
