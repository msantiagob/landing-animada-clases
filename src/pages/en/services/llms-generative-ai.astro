---
import LayoutPage from "../../../layouts/LayoutPage.astro";
import { getLangFromUrl } from "../../../i18n/utils";
import { getServicesPath } from "../../../i18n/paths";

const lang = getLangFromUrl(Astro.url);
const servicesHref = getServicesPath(lang);

const WA = "https://wa.me/573106041144?text=Hi%2C+I%27m+interested+in+the+LLMs+and+Generative+AI+service.";
---

<LayoutPage
  title="LLMs & Generative AI | Sonmyd — Miguel Zuluaga"
  description="Learn to work with large language models: GPT, Claude, Llama, RAG, embeddings, prompt engineering and AI APIs in real projects."
>
  <div class="page">
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="u-container">
        <a href={servicesHref} class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" /></svg>
          {lang === "en" ? "Services" : "Servicios"}
        </a>
        <div class="badge u-text">🧠 Level: intermediate · advanced</div>
        <h1 class="u-heading hero-title" data-sy-reveal="words">LLMs &<br />Generative AI</h1>
        <p class="u-text hero-sub" data-sy-reveal="lines">
          The most in-demand area of AI today. Learn to integrate and leverage GPT, Claude, Llama and image models in real projects.
        </p>
        <a href={WA} target="_blank" rel="noopener noreferrer" class="cta-btn">
          Start now
        </a>
      </div>
    </section>

    <section class="section u-container">
      <h2 class="u-heading sec-title" data-sy-reveal="words">What will you learn?</h2>
      <div class="cards">
        {[
          { n: "01", t: "Advanced Prompt Engineering", d: "Zero-shot, few-shot, chain-of-thought, role prompting, self-consistency. Techniques to get the most out of any LLM." },
          { n: "02", t: "AI APIs (OpenAI, Anthropic, HF)", d: "Real code integration in Python: completions, chat, embeddings, function calling and token management." },
          { n: "03", t: "RAG & Embeddings", d: "Retrieval-Augmented Generation: vector databases (Pinecone, Chroma), semantic search and Q&A systems on your own documents." },
          { n: "04", t: "Fine-tuning & local models", d: "When and how to fine-tune models. Running Llama, Mistral or Phi locally with Ollama and other tools." },
        ].map((c) => (
          <div class="card">
            <span class="card-n">{c.n}</span>
            <h3 class="u-text card-title">{c.t}</h3>
            <p class="u-text card-desc">{c.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section section--alt">
      <div class="u-container">
        <h2 class="u-heading sec-title" data-sy-reveal="words">Tools you'll use</h2>
        <ul class="topics-list u-text">
          <li>OpenAI API (GPT-4o)</li>
          <li>Anthropic API (Claude)</li>
          <li>Hugging Face Transformers</li>
          <li>LangChain</li>
          <li>Pinecone / ChromaDB</li>
          <li>Ollama (local models)</li>
          <li>Llama, Mistral, Phi</li>
          <li>Streamlit / Gradio (demos)</li>
        </ul>
      </div>
    </section>

    <section class="section u-container">
      <h2 class="u-heading sec-title" data-sy-reveal="words">Who is it for?</h2>
      <ul class="for-list u-text">
        <li>You have Python foundations and want to build generative AI applications.</li>
        <li>You want to integrate LLMs into products, startups or professional projects.</li>
        <li>You need to build a Q&A system or chatbot on your own documents.</li>
        <li>You're interested in the language model field at a deep technical level.</li>
      </ul>
    </section>

    <section class="section cta-sec u-container">
      <h2 class="u-heading cta-title" data-sy-reveal="words">Ready to master LLMs?</h2>
      <p class="u-text cta-text">We start with a free session to define exactly what to build and how.</p>
      <a href={WA} target="_blank" rel="noopener noreferrer" class="cta-btn">
        Talk via WhatsApp →
      </a>
    </section>
  </div>
</LayoutPage>

<style>
  @import "../../../styles/_service-page.css";
</style>
