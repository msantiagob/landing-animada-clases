---
import LayoutPage from "../../../layouts/LayoutPage.astro";
import { getLangFromUrl } from "../../../i18n/utils";
import { getServicesPath } from "../../../i18n/paths";

const lang = getLangFromUrl(Astro.url);
const servicesHref = getServicesPath(lang);

const WA = "https://wa.me/573106041144?text=Hi%2C+I%27m+interested+in+the+native+apps+service.";
---

<LayoutPage
  title="Native Apps | Sonmyd — Miguel Zuluaga"
  description="Native mobile and desktop application development. iOS, Android and cross-platform with React Native and Tauri for maximum performance."
>
  <div class="page">
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="u-container">
        <a href={servicesHref} class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" /></svg>
          {lang === "en" ? "Services" : "Servicios"}
        </a>
        <div class="badge u-text">📱 iOS · Android · Desktop</div>
        <h1 class="u-heading hero-title" data-sy-reveal="words">Native<br />Apps</h1>
        <p class="u-text hero-sub" data-sy-reveal="lines">
          Mobile and desktop apps that feel native: fluid, fast and with full access to device hardware. One codebase, multiple platforms.
        </p>
        <a href={WA} target="_blank" rel="noopener noreferrer" class="cta-btn">
          Let's talk about your app
        </a>
      </div>
    </section>

    <section class="section u-container">
      <h2 class="u-heading sec-title" data-sy-reveal="words">What do we build?</h2>
      <div class="cards">
        {[
          { n: "01", t: "Mobile apps (iOS & Android)", d: "Cross-platform applications with React Native or Expo. One codebase with native experience on both platforms." },
          { n: "02", t: "Desktop apps", d: "Applications for macOS, Windows and Linux with Tauri (Rust + Web) or Electron. Fast, lightweight and with system access." },
          { n: "03", t: "Apps with embedded AI", d: "Applications that run AI models locally (on-device): voice recognition, vision, text processing without internet." },
          { n: "04", t: "Store publication", d: "Configuration and submission to App Store (Apple) and Google Play. Signing, certificates, policy review and OTA updates." },
        ].map((c) => (
          <div class="card">
            <span class="card-n">{c.n}</span>
            <h3 class="u-text card-title">{c.t}</h3>
            <p class="u-text card-desc">{c.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section section--alt">
      <div class="u-container">
        <h2 class="u-heading sec-title" data-sy-reveal="words">Technology stack</h2>
        <ul class="topics-list u-text">
          <li>React Native / Expo</li>
          <li>Tauri (desktop)</li>
          <li>TypeScript</li>
          <li>Swift (native iOS)</li>
          <li>Kotlin (native Android)</li>
          <li>Core ML / TensorFlow Lite</li>
          <li>SQLite / Realm (local DB)</li>
          <li>Push notifications (FCM/APNs)</li>
        </ul>
      </div>
    </section>

    <section class="section u-container">
      <h2 class="u-heading sec-title" data-sy-reveal="words">Who is it for?</h2>
      <ul class="for-list u-text">
        <li>Startups that need a functional mobile app quickly and on a controlled budget.</li>
        <li>Companies that want to take their web tool to iOS and Android.</li>
        <li>Projects that require AI processing directly on the device.</li>
        <li>Businesses that need a desktop app for their internal team.</li>
      </ul>
    </section>

    <section class="section cta-sec u-container">
      <h2 class="u-heading cta-title" data-sy-reveal="words">Ready to turn your idea into an app?</h2>
      <p class="u-text cta-text">Tell me what you want to build and I'll give you an honest proposal of time and scope.</p>
      <a href={WA} target="_blank" rel="noopener noreferrer" class="cta-btn">
        Talk via WhatsApp →
      </a>
    </section>
  </div>
</LayoutPage>

<style>
  @import "../../../styles/_service-page.css";
</style>
