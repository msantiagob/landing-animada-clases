---
import LayoutPage from "../../../layouts/LayoutPage.astro";
import { getLangFromUrl } from "../../../i18n/utils";
import { getServicesPath } from "../../../i18n/paths";

const lang = getLangFromUrl(Astro.url);
const servicesHref = getServicesPath(lang);

const WA = "https://wa.me/573106041144?text=Hi%2C+I%27m+interested+in+the+automations+service.";
---

<LayoutPage
  title="Automations | Sonmyd — Miguel Zuluaga"
  description="Automate repetitive business processes with smart flows, tool integrations and bots that work for you."
>
  <div class="page">
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="u-container">
        <a href={servicesHref} class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" /></svg>
          {lang === "en" ? "Services" : "Servicios"}
        </a>
        <div class="badge u-text">🔄 No-code · Low-code · Custom</div>
        <h1 class="u-heading hero-title" data-sy-reveal="words">Automations</h1>
        <p class="u-text hero-sub" data-sy-reveal="lines">
          Connect your tools, eliminate manual work and let automated flows do the heavy lifting. From simple integrations to complex AI-powered pipelines.
        </p>
        <a href={WA} target="_blank" rel="noopener noreferrer" class="cta-btn">
          Let's talk about your process
        </a>
      </div>
    </section>

    <section class="section u-container">
      <h2 class="u-heading sec-title" data-sy-reveal="words">What do we automate?</h2>
      <div class="cards">
        {[
          { n: "01", t: "Workflow integration between apps", d: "We connect Gmail, Notion, Slack, HubSpot, Google Sheets and hundreds of other tools so information flows automatically." },
          { n: "02", t: "AI-powered data processing", d: "Pipelines that receive documents, analyze them with LLMs and generate reports, responses or automatic actions." },
          { n: "03", t: "Bots & automated assistants", d: "Chatbots for WhatsApp, Slack or web that respond, classify and escalate inquiries without human intervention." },
          { n: "04", t: "Scraping & monitoring", d: "Automated web data extraction, price and competitor monitoring with real-time alerts." },
        ].map((c) => (
          <div class="card">
            <span class="card-n">{c.n}</span>
            <h3 class="u-text card-title">{c.t}</h3>
            <p class="u-text card-desc">{c.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section section--alt">
      <div class="u-container">
        <h2 class="u-heading sec-title" data-sy-reveal="words">Tools we use</h2>
        <ul class="topics-list u-text">
          <li>n8n / Make (Integromat)</li>
          <li>Zapier</li>
          <li>Custom Python scripts</li>
          <li>LangChain / CrewAI</li>
          <li>WhatsApp Business API</li>
          <li>Playwright / Puppeteer</li>
          <li>Google Apps Script</li>
          <li>Webhooks & REST APIs</li>
        </ul>
      </div>
    </section>

    <section class="section u-container">
      <h2 class="u-heading sec-title" data-sy-reveal="words">Who is it for?</h2>
      <ul class="for-list u-text">
        <li>Businesses that lose hours on manual and repetitive tasks.</li>
        <li>Sales or marketing teams that want automated follow-up flows.</li>
        <li>Companies that receive many documents and want to process them with AI.</li>
        <li>Entrepreneurs who want to scale without hiring more people.</li>
      </ul>
    </section>

    <section class="section cta-sec u-container">
      <h2 class="u-heading cta-title" data-sy-reveal="words">What process do you want to automate?</h2>
      <p class="u-text cta-text">Tell me the problem and we'll design the simplest and most effective solution.</p>
      <a href={WA} target="_blank" rel="noopener noreferrer" class="cta-btn">
        Talk via WhatsApp →
      </a>
    </section>
  </div>
</LayoutPage>

<style>
  @import "../../../styles/_service-page.css";
</style>
