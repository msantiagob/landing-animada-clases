---
import LayoutPage from "../../../layouts/LayoutPage.astro";
import { getLangFromUrl } from "../../../i18n/utils";
import { getServicesPath } from "../../../i18n/paths";

const lang = getLangFromUrl(Astro.url);
const servicesHref = getServicesPath(lang);

const WA = "https://wa.me/573106041144?text=Hi%2C+I%27m+interested+in+the+web+application+development+service.";
---

<LayoutPage
  title="Web Applications | sonmyd — Miguel Zuluaga"
  description="Modern, fast and scalable web application development. From landing pages to full platforms with the most in-demand technologies."
>
  <div class="page">
    <section class="hero">
      <div class="hero-bg"></div>
      <div class="u-container">
        <a href={servicesHref} class="back-link">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M17 10a.75.75 0 0 1-.75.75H5.612l4.158 3.96a.75.75 0 1 1-1.04 1.08l-5.5-5.25a.75.75 0 0 1 0-1.08l5.5-5.25a.75.75 0 1 1 1.04 1.08L5.612 9.25H16.25A.75.75 0 0 1 17 10Z" clip-rule="evenodd" /></svg>
          {lang === "en" ? "Services" : "Servicios"}
        </a>
        <div class="badge u-text">🌐 Web · Full Stack</div>
        <h1 class="u-heading hero-title" data-sy-reveal="words">Web<br />Applications</h1>
        <p class="u-text hero-sub" data-sy-reveal="lines">
          Modern, fast and scalable web development. From a high-impact landing page to full platforms with backend, APIs and database.
        </p>
        <a href={WA} target="_blank" rel="noopener noreferrer" class="cta-btn">
          Let's talk about your project
        </a>
      </div>
    </section>

    <section class="section u-container">
      <h2 class="u-heading sec-title" data-sy-reveal="words">What do we build?</h2>
      <div class="cards">
        {[
          { n: "01", t: "Landing pages & websites", d: "Fast sites, optimized for SEO and conversion. Animations, responsive design and top-level performance." },
          { n: "02", t: "Full-stack web applications", d: "Platforms with authentication, database, REST or GraphQL APIs and admin dashboards." },
          { n: "03", t: "AI integrations", d: "Web apps that consume LLMs, process documents, generate content or automate decisions using AI." },
          { n: "04", t: "Dashboards & internal tools", d: "Analytics dashboards, lightweight CRMs and custom tools for teams and companies." },
        ].map((c) => (
          <div class="card">
            <span class="card-n">{c.n}</span>
            <h3 class="u-text card-title">{c.t}</h3>
            <p class="u-text card-desc">{c.d}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="section section--alt">
      <div class="u-container">
        <h2 class="u-heading sec-title" data-sy-reveal="words">Technology stack</h2>
        <ul class="topics-list u-text">
          <li>Astro / Next.js / React</li>
          <li>TypeScript</li>
          <li>Node.js / Python (FastAPI)</li>
          <li>PostgreSQL / Supabase</li>
          <li>Tailwind CSS</li>
          <li>REST & GraphQL APIs</li>
          <li>Vercel / Netlify</li>
          <li>Stripe (payments)</li>
        </ul>
      </div>
    </section>

    <section class="section u-container">
      <h2 class="u-heading sec-title" data-sy-reveal="words">Who is it for?</h2>
      <ul class="for-list u-text">
        <li>Entrepreneurs and startups that need their first web platform.</li>
        <li>Companies that want to digitize or automate internal processes.</li>
        <li>Businesses that need to integrate AI into their existing web product.</li>
        <li>Professionals who need a high-impact digital presence.</li>
      </ul>
    </section>

    <section class="section cta-sec u-container">
      <h2 class="u-heading cta-title" data-sy-reveal="words">Do you have a project in mind?</h2>
      <p class="u-text cta-text">Tell me what you need and I'll give you a clear proposal without beating around the bush.</p>
      <a href={WA} target="_blank" rel="noopener noreferrer" class="cta-btn">
        Talk via WhatsApp →
      </a>
    </section>
  </div>
</LayoutPage>

<style>
  @import "../../../styles/_service-page.css";
</style>
