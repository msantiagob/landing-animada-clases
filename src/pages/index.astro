---
import Layout from "../layouts/Layout.astro";
import HeroHome from "../components/HeroHome.astro";
import TextMarquee from "../components/TextMarquee.astro";
import Faqs from "../components/Faqs.astro";
import StepsTimeline from "../components/StepsTimeline.astro";
import Statements from "../components/Statements.astro";
import Introducing from "../components/Introducing.astro";
import GL from "../components/GL.astro";
import GLPlaces from "../components/GlPlaces.astro";
import ContactModal from "../components/ContactModal.astro";
import FloatingBubbles from "../components/FloatingBubbles.astro";

import fotoMiguel from "../assets/img/foto_miguel.png";

const siteUrl = "https://sonmyd.co/";

const schemaFAQ = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "¿Qué puede automatizar Sonmyd en mi negocio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sonmyd automatiza Google Calendar (citas, recordatorios y agendamiento), WhatsApp Business (respuestas automáticas, notificaciones y chatbots), creación y mantenimiento de sitios web, y cualquier flujo repetitivo de tu empresa usando inteligencia artificial.",
      },
    },
    {
      "@type": "Question",
      "name": "¿Cómo funciona la integración con Google Calendar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Conectamos tu Google Calendar para agendar citas automáticamente, enviar recordatorios a tus clientes, bloquear horarios disponibles y sincronizar con tus herramientas existentes. Sin intervención manual.",
      },
    },
    {
      "@type": "Question",
      "name": "¿Qué tipo de automatizaciones hace Sonmyd con WhatsApp?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Implementamos chatbots inteligentes, respuestas automáticas 24/7, notificaciones de citas y pedidos, calificación de leads y escalado a humanos. Todo integrado con WhatsApp Business API.",
      },
    },
    {
      "@type": "Question",
      "name": "¿Necesito conocimientos técnicos para usar Sonmyd?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "No. Sonmyd se encarga de toda la parte técnica. Tú defines qué quieres automatizar y nosotros construimos e implementamos la solución. Solo necesitas tener claros tus procesos de negocio.",
      },
    },
    {
      "@type": "Question",
      "name": "¿Cuánto tiempo tarda en estar lista mi automatización?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Depende del alcance. Una automatización básica de WhatsApp o Calendar puede estar lista en pocos días. Un sitio web completo con automatizaciones integradas puede tomar una a tres semanas.",
      },
    },
    {
      "@type": "Question",
      "name": "¿Hay una sesión gratuita para evaluar mi proyecto?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sí. La primera sesión de diagnóstico es completamente gratuita. Analizamos tus procesos, identificamos qué automatizar y te presentamos un plan concreto sin ningún compromiso.",
      },
    },
  ],
};

const schemaBreadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Inicio",
      "item": siteUrl,
    },
  ],
};
---

<Layout title="Sonmyd — Automatizaciones con IA: WhatsApp, Google Calendar y Sitios Web">
  <Fragment slot="head">
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schemaFAQ)}</script>`} />
    <Fragment set:html={`<script type="application/ld+json">${JSON.stringify(schemaBreadcrumb)}</script>`} />
  </Fragment>
  <!-- ══════════════════════════════════════════════════════════════════════
       APP IDENTITY — sección siempre visible, sin animaciones, sin JS.
       Google OAuth verification requiere que el nombre y propósito de la
       app sean visibles en texto plano, sin depender de JavaScript.
       ══════════════════════════════════════════════════════════════════════ -->
  <section class="app-id" aria-labelledby="app-id-title">
    <div class="u-container app-id__inner">
      <div class="app-id__brand">
        <span class="app-id__name" id="app-id-title">Sonmyd</span>
        <span class="app-id__sep" aria-hidden="true">·</span>
        <span class="app-id__tagline">Plataforma de automatización con IA</span>
      </div>
      <p class="app-id__purpose">
        <strong>Sonmyd</strong> accede a <strong>Google Calendar</strong> a través de OAuth para crear y gestionar citas automáticamente. También integra <strong>WhatsApp Business</strong> para responder clientes 24/7 y construye sitios web profesionales para tu negocio.
      </p>
      <nav class="app-id__links" aria-label="Legal">
        <a href="/privacidad">Política de Privacidad</a>
        <span aria-hidden="true">·</span>
        <a href="/terminos">Términos de Uso</a>
      </nav>
    </div>
  </section>

  <div id="inicio">
    <HeroHome
      title="Sonmyd: automatiza tu negocio con IA."
      subtitle="Conecta Google Calendar, gestiona WhatsApp, crea tu sitio web y elimina el trabajo repetitivo. Tecnología que trabaja por ti, 24/7."
      cta={{
        title: "Empieza gratis",
        url: "#contacto",
      }}
      ctaModalPlan="Sesión Gratuita"
      whatsappUrl="https://wa.me/573106041144"
    />
    <div class="photo-inner">
      <img src={fotoMiguel.src} alt="Miguel Zuluaga — Sonmyd" />
    </div>
  </div>

  <div id="clases">
    <Introducing
      title="Sonmyd es tu equipo de automatización con IA"
      text="Construimos integraciones inteligentes entre tus herramientas: agenda citas sola con Google Calendar, responde clientes en WhatsApp las 24 horas, publica tu sitio web en días. Todo con IA, sin código, sin complicaciones."
      cta={{
        title: "Ver todos los servicios",
        url: "/servicios",
      }}
    />
  </div>

  <TextMarquee
    class="marquee"
    texts={[
      "Google Calendar",
      "WhatsApp Business",
      "Sitios Web",
      "Automatización IA",
      "Chatbots",
      "Integraciones",
    ]}
  />

  <div id="metodologia">
    <StepsTimeline
      title="Cómo funciona Sonmyd"
      items={[
        {
          title: "Diagnóstico de procesos",
          text: "Analizamos juntos qué tareas consumen tu tiempo: agendar citas, responder mensajes, actualizar tu web. Identificamos los puntos de mayor impacto.",
        },
        {
          title: "Diseño de la automatización",
          text: "Construimos flujos a medida: Calendar conectado a tu negocio, WhatsApp que responde solo, formularios que se convierten en acciones automáticas.",
        },
        {
          title: "Implementación y pruebas",
          text: "Ponemos todo en marcha, hacemos pruebas reales y ajustamos hasta que funcione perfecto. Tú lo apruebas antes de salir en vivo.",
        },
        {
          title: "Monitoreo y soporte",
          text: "Una vez activo, monitoreamos que todo funcione. Si algo cambia en tu negocio, ajustamos la automatización para que siempre esté al día.",
        },
      ]}
    />
  </div>

  <Statements
    items={[
      {
        title: "Google Calendar que agenda solo",
        text: "Tus clientes reservan citas, reciben recordatorios automáticos y tú no mueves un dedo. Sin llamadas perdidas, sin dobles reservas.",
      },
      {
        title: "WhatsApp que trabaja las 24 horas",
        text: "Un asistente inteligente responde, califica y atiende a tus clientes en WhatsApp mientras tú duermes. Escala a humanos cuando sea necesario.",
      },
      {
        title: "Tu sitio web, listo en días",
        text: "Creamos tu presencia digital profesional: rápida, optimizada para Google y conectada a tus automatizaciones desde el primer día.",
      },
    ]}
  />

  <TextMarquee
    class="marquee"
    texts={[
      "Agendamiento automático",
      "Chatbots con IA",
      "Formularios inteligentes",
      "Notificaciones automáticas",
      "Sitios web rápidos",
      "Integraciones API",
    ]}
  />

  <div id="contacto">
    <Faqs
      title="Preguntas Frecuentes"
      mobileTitle="FAQs"
      subtitle="Lo que necesitas saber sobre Sonmyd y sus automatizaciones."
      items={[
        {
          question: "¿Qué puede automatizar Sonmyd en mi negocio?",
          answer:
            "Sonmyd automatiza Google Calendar (citas, recordatorios y agendamiento), WhatsApp Business (respuestas automáticas, notificaciones y chatbots), creación y mantenimiento de sitios web, y cualquier flujo repetitivo de tu empresa usando inteligencia artificial.",
        },
        {
          question: "¿Cómo funciona la integración con Google Calendar?",
          answer:
            "Conectamos tu Google Calendar para agendar citas automáticamente, enviar recordatorios a tus clientes, bloquear horarios disponibles y sincronizar con tus herramientas existentes. Sin intervención manual.",
        },
        {
          question: "¿Qué tipo de automatizaciones hace Sonmyd con WhatsApp?",
          answer:
            "Implementamos chatbots inteligentes, respuestas automáticas 24/7, notificaciones de citas y pedidos, calificación de leads y escalado a humanos. Todo integrado con WhatsApp Business API.",
        },
        {
          question: "¿Necesito conocimientos técnicos para usar Sonmyd?",
          answer:
            "No. Sonmyd se encarga de toda la parte técnica. Tú defines qué quieres automatizar y nosotros construimos e implementamos la solución. Solo necesitas tener claros tus procesos de negocio.",
        },
        {
          question: "¿Cuánto tiempo tarda en estar lista mi automatización?",
          answer:
            "Depende del alcance. Una automatización básica de WhatsApp o Calendar puede estar lista en pocos días. Un sitio web completo con automatizaciones integradas puede tomar una a tres semanas.",
        },
        {
          question: "¿Hay una sesión gratuita para evaluar mi proyecto?",
          answer:
            "Sí. La primera sesión de diagnóstico es completamente gratuita. Analizamos tus procesos, identificamos qué automatizar y te presentamos un plan concreto sin ningún compromiso.",
        },
      ]}
    />
  </div>

  <div class="app-info u-container">
    <p class="app-info__brand">Sonmyd</p>
    <p class="app-info__desc">
      Plataforma de automatización con inteligencia artificial: integraciones con Google Calendar, WhatsApp Business, creación de sitios web y automatización de procesos empresariales. Este sitio utiliza Google Analytics (a través de Google Tag Manager) para medir el tráfico web de forma anónima.
    </p>
    <nav class="app-info__links" aria-label="Legal">
      <a href="/privacidad">Política de Privacidad</a>
      <span aria-hidden="true">·</span>
      <a href="/terminos">Términos de Uso</a>
    </nav>
  </div>

  <GL />
  <GLPlaces />
  <ContactModal />
</Layout>

<script>
  const EU = new Set([
    "ES","FR","DE","IT","PT","NL","BE","AT","CH","SE","NO","DK","FI",
    "IE","GR","PL","CZ","HU","RO","BG","HR","SK","SI","EE","LV","LT",
    "LU","MT","CY","IS","LI","AL","RS","BA","ME","MK","MD",
  ]);

  type PriceEntry = {
    amount: string;
    duration: string;
    savings?: string;
  };
  type CountryPricing = {
    individual: PriceEntry;
    paquete: PriceEntry;
  };

  const PRICING: Record<string, CountryPricing> = {
    DEFAULT: {
      individual: { amount: "$25",      duration: "session" },
      paquete:    { amount: "$220",     duration: "10 hrs",   savings: "Te ahorras $30" },
    },
    CO: {
      individual: { amount: "$80.000",  duration: "sesión" },
      paquete:    { amount: "$750.000", duration: "10 horas" },
    },
    EU: {
      individual: { amount: "€25",      duration: "sesión" },
      paquete:    { amount: "€220",     duration: "10 horas", savings: "Te ahorras €30" },
    },
    MX: {
      individual: { amount: "$450",     duration: "sesión" },
      paquete:    { amount: "$4.000",   duration: "10 horas", savings: "Te ahorras $500" },
    },
    CL: {
      individual: { amount: "$20.000",  duration: "sesión" },
      paquete:    { amount: "$180.000", duration: "10 horas", savings: "Te ahorras $20.000" },
    },
    PE: {
      individual: { amount: "S/ 85",   duration: "sesión" },
      paquete:    { amount: "S/ 750",  duration: "10 horas" },
    },
  };

  function applyPricing(pricing: CountryPricing) {
    const plans = [pricing.individual, pricing.paquete];

    plans.forEach((plan, i) => {
      const amountEl = document.querySelector<HTMLElement>(`[data-plan-amount="${i}"]`);
      const durationEl = document.querySelector<HTMLElement>(`[data-plan-duration="${i}"]`);
      const savingsEl = document.querySelector<HTMLElement>(`[data-plan-savings="${i}"]`);

      if (amountEl) amountEl.textContent = plan.amount;
      if (durationEl) durationEl.textContent = `/${plan.duration}`;
      if (savingsEl) {
        savingsEl.textContent = plan.savings ?? "";
        savingsEl.classList.toggle("visible", !!plan.savings);
      }
    });
  }

  async function getCountryCode(): Promise<string> {
    // Cloudflare CDN trace — sin límites, sin CORS, 100% confiable
    try {
      const res = await fetch("https://cloudflare.com/cdn-cgi/trace");
      const text = await res.text();
      const match = text.match(/^loc=([A-Z]{2})$/m);
      if (match?.[1]) return match[1];
    } catch { /* fall through */ }

    // Fallback: ipapi.co
    try {
      const res = await fetch("https://ipapi.co/json/");
      const data = await res.json();
      if (data.country_code) return data.country_code;
    } catch { /* fall through */ }

    return "DEFAULT";
  }

  async function detectAndApply() {
    const countryCode = await getCountryCode();

    let pricing: CountryPricing;
    if (PRICING[countryCode]) {
      pricing = PRICING[countryCode];
    } else if (EU.has(countryCode)) {
      pricing = PRICING.EU;
    } else {
      pricing = PRICING.DEFAULT;
    }

    applyPricing(pricing);
  }

  detectAndApply();
</script>

<style>
  /* ── App Identity ── siempre visible, sin animaciones ── */
  .app-id {
    position: relative;
    z-index: 1;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.03);
    /* padding-top empuja el contenido debajo del header fijo (~4.5rem alto) */
    padding: 5.5rem 0 1rem;
    opacity: 1 !important;
    visibility: visible !important;
  }
  .app-id__inner {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    opacity: 1 !important;
  }
  .app-id__brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    opacity: 1 !important;
  }
  .app-id__name {
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: #fff;
    opacity: 1 !important;
  }
  .app-id__sep {
    color: rgba(255, 255, 255, 0.3);
  }
  .app-id__tagline {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    opacity: 1 !important;
  }
  .app-id__purpose {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.5;
    max-width: 56rem;
    margin: 0;
    opacity: 1 !important;

    strong {
      color: rgba(255, 255, 255, 0.8);
      font-weight: 600;
    }
  }
  .app-id__links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.3);
    opacity: 1 !important;
  }
  .app-id__links a {
    color: rgba(50, 170, 255, 0.7);
    text-decoration: underline;
    text-underline-offset: 2px;
    opacity: 1 !important;
  }
  .app-id__links a:hover {
    color: #32aaff;
  }

  .app-info {
    padding: 3rem 0 2rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }
  .app-info__brand {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.35);
  }
  .app-info__desc {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.3);
    max-width: 46rem;
    line-height: 1.6;
  }
  .app-info__links {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.8rem;
    color: rgba(255,255,255,0.3);
  }
  .app-info__links a {
    color: rgba(255,255,255,0.45);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  .app-info__links a:hover {
    color: rgba(255,255,255,0.75);
  }

  .marquee {
    padding: 2rem 0;
    z-index: 9;
  }

  .photo-inner {
    margin: auto;
    position: relative;
    z-index: 9;
    width: 22rem;
    height: 26rem;
    border-radius: 2rem;
    overflow: hidden;
    border: 1.5px solid rgba(50, 170, 255, 0.5);
    box-shadow:
      0 0 60px rgba(50, 170, 255, 0.25),
      0 0 120px rgba(235, 14, 56, 0.08),
      inset 0 0 30px rgba(0, 0, 0, 0.5);

    @media (--mq-tablet) {
      width: 18rem;
      height: 22rem;
    }

    @media (--mq-phone) {
      width: 14rem;
      height: 17rem;
    }

    img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center top;
    }
  }
</style>
